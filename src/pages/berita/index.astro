---
/**
 * Tips & Trik (blog) index — Gopuff-style editorial: big featured post (image left +
 * content right), two horizontal secondary posts, then a filterable card grid.
 */
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../../components/content/BlogCard.astro';
import blogPosts from '../../data/blog-posts.json';

const posts = (blogPosts as any[]).slice().sort((a, b) => new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime());
const featured = posts[0];
const secondary = posts.slice(1, 3);
const rest = posts.slice(3);
const categories = [...new Set(posts.map((p) => p.category))];
const fmt = (d: string) => new Date(d).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
---
<PageLayout
  title="Tips & Trik - Level Garment"
  description="Panduan, inspirasi, dan tips seputar jersey, jaket, dan kaos custom untuk tim, kelas, dan komunitas."
  showHero={false}
>
  <section class="lg-blog">
    <div class="lg-blog-wrap">
      <header class="lg-blog-head">
        <h1 class="lg-blog-h1">Tips &amp; Trik</h1>
        <p class="lg-blog-sub">Panduan, inspirasi &amp; tips seputar custom apparel — buat tim, kelas, dan komunitasmu.</p>
      </header>

      {featured && (
        <a class="lg-blog-feat" href={`/berita/${featured.slug}/`}>
          <div class="lg-blog-feat-img">
            {featured.image ? <img src={featured.image} alt={featured.title} /> : <div class="lg-blog-ph"></div>}
          </div>
          <div class="lg-blog-feat-body">
            <span class="lg-blog-eyebrow">{featured.category}</span>
            <h2 class="lg-blog-feat-title">{featured.title}</h2>
            <p class="lg-blog-feat-ex">{featured.excerpt}</p>
            <time class="lg-blog-date" datetime={featured.publishDate}>{fmt(featured.publishDate)}</time>
          </div>
        </a>
      )}

      {secondary.length > 0 && (
        <div class="lg-blog-sec">
          {secondary.map((p) => (
            <a class="lg-blog-mini" href={`/berita/${p.slug}/`}>
              <div class="lg-blog-mini-img">
                {p.image ? <img src={p.image} alt={p.title} /> : <div class="lg-blog-ph"></div>}
              </div>
              <div class="lg-blog-mini-body">
                <h3 class="lg-blog-mini-title">{p.title}</h3>
                <time class="lg-blog-date" datetime={p.publishDate}>{fmt(p.publishDate)}</time>
              </div>
            </a>
          ))}
        </div>
      )}

      <div class="lg-blog-bar">
        <h2 class="lg-blog-more-h">Semua Artikel</h2>
        {categories.length > 1 && (
          <div class="lg-blog-filter" data-filter>
            <button class="is-active" data-cat="all">Semua</button>
            {categories.map((c) => (<button data-cat={c}>{c}</button>))}
          </div>
        )}
      </div>

      <div class="lg-blog-grid" data-grid>
        {rest.map((p) => (
          <div class="lg-blog-item" data-category={p.category}>
            <BlogCard title={p.title} slug={p.slug} publishDate={p.publishDate} category={p.category} image={p.image} />
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .lg-blog { background: #fff; padding: clamp(2.5rem, 6vw, 4.5rem) 0 clamp(3rem, 7vw, 5rem); }
  .lg-blog-wrap { max-width: 74rem; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 2.5rem); }

  .lg-blog-head { margin-bottom: clamp(2rem, 4vw, 3rem); }
  .lg-blog-h1 { font-family:'Inter',sans-serif; font-weight: 800; font-size: clamp(2.2rem, 5vw, 3.4rem); line-height: 1.02; letter-spacing: -.03em; color: #1A1A2E; margin: 0 0 .6rem; }
  .lg-blog-sub { font-family:'Inter',sans-serif; font-size: clamp(1.02rem, 1.5vw, 1.2rem); line-height: 1.5; color: #6a6a7c; max-width: 42rem; margin: 0; }

  /* featured: image left, content right */
  .lg-blog-feat { display: grid; grid-template-columns: 1.05fr 1fr; gap: clamp(1.5rem, 4vw, 3.5rem); align-items: center; text-decoration: none; color: #1A1A2E; margin-bottom: clamp(2.2rem, 5vw, 3.5rem); }
  @media (max-width: 768px) { .lg-blog-feat { grid-template-columns: 1fr; gap: 1.3rem; } }
  .lg-blog-feat-img { aspect-ratio: 16/11; overflow: hidden; border-radius: 1.2rem; background: #eee9f3; }
  .lg-blog-feat-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .6s ease; }
  @media (hover:hover){ .lg-blog-feat:hover .lg-blog-feat-img img { transform: scale(1.03); } }
  .lg-blog-ph { width: 100%; height: 100%; background: linear-gradient(135deg,#d8c8ee,#eee9f3); }
  .lg-blog-feat-body { min-width: 0; }
  .lg-blog-eyebrow { display: block; font-family:'Inter',sans-serif; font-weight: 700; font-size: .74rem; letter-spacing: .14em; text-transform: uppercase; color: #9a8db0; margin-bottom: .9rem; }
  .lg-blog-feat-title { font-family:'Inter',sans-serif; font-weight: 800; font-size: clamp(1.7rem, 3.4vw, 2.7rem); line-height: 1.08; letter-spacing: -.02em; color: #1A1A2E; margin: 0 0 1rem; transition: color .2s ease; }
  @media (hover:hover){ .lg-blog-feat:hover .lg-blog-feat-title { color: #9A66C2; } }
  .lg-blog-feat-ex { font-family:'Inter',sans-serif; font-size: clamp(1rem, 1.4vw, 1.15rem); line-height: 1.6; color: #5a5a6e; margin: 0 0 1.4rem;
    display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
  .lg-blog-date { font-family:'Inter',sans-serif; font-size: .9rem; color: #9a9aa8; }

  /* two secondary, horizontal */
  .lg-blog-sec { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.3rem, 3vw, 2.5rem); margin-bottom: clamp(2.5rem, 5vw, 4rem); }
  @media (max-width: 768px) { .lg-blog-sec { grid-template-columns: 1fr; gap: 1.4rem; } }
  .lg-blog-mini { display: grid; grid-template-columns: 9rem 1fr; gap: 1.1rem; align-items: center; text-decoration: none; color: #1A1A2E; }
  @media (max-width: 420px) { .lg-blog-mini { grid-template-columns: 7rem 1fr; gap: .9rem; } }
  .lg-blog-mini-img { aspect-ratio: 1/1; overflow: hidden; border-radius: .9rem; background: #eee9f3; }
  .lg-blog-mini-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .5s ease; }
  @media (hover:hover){ .lg-blog-mini:hover .lg-blog-mini-img img { transform: scale(1.05); } }
  .lg-blog-mini-title { font-family:'Inter',sans-serif; font-weight: 800; font-size: clamp(1.02rem, 1.5vw, 1.18rem); line-height: 1.25; letter-spacing: -.01em; color: #1A1A2E; margin: 0 0 .45rem;
    display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; transition: color .2s ease; }
  @media (hover:hover){ .lg-blog-mini:hover .lg-blog-mini-title { color: #9A66C2; } }

  /* section bar */
  .lg-blog-bar { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem; padding-top: clamp(1.5rem, 3vw, 2.2rem); border-top: 1px solid rgba(26,26,46,.1); margin-bottom: clamp(1.4rem, 3vw, 2rem); }
  .lg-blog-more-h { font-family:'Inter',sans-serif; font-weight: 800; font-size: clamp(1.5rem, 3vw, 2.1rem); letter-spacing: -.02em; color: #1A1A2E; margin: 0; }
  .lg-blog-filter { display: flex; flex-wrap: wrap; gap: .5rem; }
  .lg-blog-filter button { font-family:'Inter',sans-serif; font-weight: 600; font-size: .85rem; color: #6a6a7c; background: #f4f1f9; border: 1.5px solid transparent; border-radius: 999px; padding: .45rem 1rem; cursor: pointer; transition: all .2s ease; }
  @media (hover:hover){ .lg-blog-filter button:hover { color: #9A66C2; } }
  .lg-blog-filter button.is-active { background: #1A1A2E; color: #fff; }

  /* grid */
  .lg-blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(15.5rem, 1fr)); gap: clamp(1.4rem, 2.5vw, 2.2rem) clamp(1.1rem, 2vw, 1.7rem); }
  .lg-blog-item.is-hidden { display: none; }
</style>

<script>
  const wrap = document.querySelector<HTMLElement>('[data-filter]');
  const items = Array.from(document.querySelectorAll<HTMLElement>('.lg-blog-item'));
  wrap?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;
    wrap.querySelectorAll('button').forEach((b) => b.classList.toggle('is-active', b === btn));
    const cat = btn.dataset.cat;
    items.forEach((it) => it.classList.toggle('is-hidden', cat !== 'all' && it.dataset.category !== cat));
  });
</script>
