---
/**
 * Tips & Trik (blog) index — editorial layout: branded header, featured latest post,
 * filterable grid of article cards. Replaces the generic grid.
 */
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../../components/content/BlogCard.astro';
import blogPosts from '../../data/blog-posts.json';

const posts = (blogPosts as any[]).slice().sort((a, b) => new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime());
const featured = posts[0];
const rest = posts.slice(1);
const categories = [...new Set(posts.map((p) => p.category))];
const fmt = (d: string) => new Date(d).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
const readTime = (p: any) => Math.max(1, Math.ceil((p.content || '').split(' ').length / 200));
---
<PageLayout
  title="Tips & Trik - Level Garment"
  description="Panduan, inspirasi, dan tips seputar jersey, jaket, dan kaos custom untuk tim, kelas, dan komunitas."
  showHero={false}
>
  <section class="lg-blog">
    <div class="lg-blog-wrap">
      <header class="lg-blog-head">
        <span class="lg-blog-eyebrow">Tips &amp; Trik</span>
        <h1 class="lg-blog-title">Tips &amp; Trik Custom Apparel</h1>
        <p class="lg-blog-sub">Panduan, inspirasi &amp; tips seputar jersey, jaket, dan kaos custom buat tim, kelas, dan komunitasmu.</p>
      </header>

      {featured && (
        <a class="lg-blog-feat" href={`/berita/${featured.slug}/`}>
          <div class="lg-blog-feat-img">
            {featured.image ? <img src={featured.image} alt={featured.title} /> : <div class="lg-blog-ph"></div>}
            <span class="lg-blog-feat-tag">Terbaru</span>
          </div>
          <div class="lg-blog-feat-body">
            <span class="lg-blog-chip">{featured.category}</span>
            <h2 class="lg-blog-feat-title">{featured.title}</h2>
            <p class="lg-blog-feat-ex">{featured.excerpt}</p>
            <span class="lg-blog-meta">{fmt(featured.publishDate)} · {readTime(featured)} menit baca</span>
          </div>
        </a>
      )}

      {categories.length > 1 && (
        <div class="lg-blog-filter" data-filter>
          <button class="is-active" data-cat="all">Semua</button>
          {categories.map((c) => (<button data-cat={c}>{c}</button>))}
        </div>
      )}

      <div class="lg-blog-grid" data-grid>
        {rest.map((p) => (
          <div class="lg-blog-item" data-category={p.category}>
            <BlogCard title={p.title} slug={p.slug} excerpt={p.excerpt} publishDate={p.publishDate} category={p.category} image={p.image} />
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .lg-blog { background: #f7f4fb; padding: clamp(2.5rem, 6vw, 4.5rem) 0; }
  .lg-blog-wrap { max-width: 70rem; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 2rem); }

  .lg-blog-head { text-align: center; margin-bottom: clamp(1.8rem, 4vw, 2.8rem); }
  .lg-blog-eyebrow { display: inline-block; font-family:'Inter',sans-serif; font-weight:700; font-size:.72rem; letter-spacing:.22em; text-transform:uppercase; color:#9A66C2; padding:.32rem .85rem; border:1.5px solid rgba(175,122,213,.5); border-radius:999px; margin-bottom:1rem; }
  .lg-blog-title { font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(2rem,5vw,3rem); line-height:1.04; letter-spacing:-.02em; color:#1A1A2E; margin:0 0 .7rem; }
  .lg-blog-sub { font-family:'Inter',sans-serif; font-size:clamp(1rem,1.4vw,1.15rem); line-height:1.55; color:#5a5a6e; max-width:40rem; margin:0 auto; }

  /* featured */
  .lg-blog-feat { display:grid; grid-template-columns: 1.15fr 1fr; gap:0; background:#fff; border:1px solid rgba(26,26,46,.08); border-radius:1.3rem; overflow:hidden; text-decoration:none; color:#1A1A2E;
    box-shadow:0 22px 48px -30px rgba(26,26,46,.55); margin-bottom: clamp(2rem,4vw,3rem); transition: transform .25s ease, box-shadow .25s ease; }
  @media (hover:hover){ .lg-blog-feat:hover { transform: translateY(-3px); box-shadow:0 30px 56px -30px rgba(70,35,110,.5); } }
  @media (max-width: 720px){ .lg-blog-feat { grid-template-columns: 1fr; } }
  .lg-blog-feat-img { position:relative; aspect-ratio: 16/11; overflow:hidden; background:#ece6f3; }
  .lg-blog-feat-img img { width:100%; height:100%; object-fit:cover; display:block; transition: transform .5s ease; }
  @media (hover:hover){ .lg-blog-feat:hover .lg-blog-feat-img img { transform: scale(1.04); } }
  .lg-blog-feat-tag { position:absolute; top:1rem; left:1rem; background:#1A1A2E; color:#fff; font-family:'Inter',sans-serif; font-weight:700; font-size:.68rem; letter-spacing:.1em; text-transform:uppercase; padding:.34rem .7rem; border-radius:999px; }
  .lg-blog-ph { width:100%; height:100%; background:linear-gradient(135deg,#d8c8ee,#ece6f3); }
  .lg-blog-feat-body { padding: clamp(1.5rem,3vw,2.4rem); display:flex; flex-direction:column; justify-content:center; }
  .lg-blog-chip { align-self:flex-start; font-family:'Inter',sans-serif; font-weight:700; font-size:.7rem; letter-spacing:.08em; text-transform:uppercase; color:#9A66C2; background:rgba(175,122,213,.13); padding:.3rem .7rem; border-radius:999px; margin-bottom:.9rem; }
  .lg-blog-feat-title { font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(1.3rem,2.4vw,1.8rem); line-height:1.18; letter-spacing:-.01em; margin:0 0 .7rem; color:#1A1A2E; }
  .lg-blog-feat-ex { font-family:'Inter',sans-serif; font-size:.98rem; line-height:1.55; color:#5a5a6e; margin:0 0 1.1rem;
    display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
  .lg-blog-meta { font-family:'Inter',sans-serif; font-size:.85rem; color:#8a8a9c; font-weight:500; }

  /* filter */
  .lg-blog-filter { display:flex; flex-wrap:wrap; gap:.5rem; justify-content:center; margin-bottom: clamp(1.5rem,3vw,2.2rem); }
  .lg-blog-filter button { font-family:'Inter',sans-serif; font-weight:600; font-size:.88rem; color:#5a5a6e; background:#fff; border:1.5px solid rgba(26,26,46,.12); border-radius:999px; padding:.5rem 1.1rem; cursor:pointer; transition: all .2s ease; }
  @media (hover:hover){ .lg-blog-filter button:hover { border-color:#AF7AD5; color:#9A66C2; } }
  .lg-blog-filter button.is-active { background:#1A1A2E; border-color:#1A1A2E; color:#fff; }

  /* grid */
  .lg-blog-grid { display:grid; grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr)); gap: clamp(1.1rem, 2vw, 1.6rem); }
  .lg-blog-item.is-hidden { display:none; }
</style>

<script>
  const wrap = document.querySelector<HTMLElement>('[data-filter]');
  const items = Array.from(document.querySelectorAll<HTMLElement>('.lg-blog-item'));
  wrap?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;
    wrap.querySelectorAll('button').forEach((b) => b.classList.toggle('is-active', b === btn));
    const cat = btn.dataset.cat;
    items.forEach((it) => it.classList.toggle('is-hidden', cat !== 'all' && it.dataset.category !== cat));
  });
</script>
