---
import BlogLayout from '../../layouts/BlogLayout.astro';
import BlogCard from '../../components/content/BlogCard.astro';
import blogPosts from '../../data/blog-posts.json';

export const getStaticPaths = () => {
  const posts = blogPosts as any[];
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: {
      title: post.title,
      description: post.excerpt,
      publishDate: post.publishDate,
      modifiedDate: post.publishDate,
      category: post.category,
      readTime: Math.ceil(post.content.split(' ').length / 200),
      image: post.image,
      // strip the duplicate leading <h1> (same as the title already shown in the hero)
      content: post.content.replace(/^\s*<h1\b[^>]*>[\s\S]*?<\/h1>\s*/i, ''),
    },
  }));
};

const { title, description, image, publishDate, modifiedDate, category, readTime, content } = Astro.props;
const posts = blogPosts as any[];
let related = posts.filter((p) => p.category === category && p.title !== title).slice(0, 3);
if (related.length < 3) {
  const more = posts.filter((p) => p.title !== title && !related.some((r) => r.slug === p.slug)).slice(0, 3 - related.length);
  related = [...related, ...more];
}
---

<BlogLayout
  title={title}
  description={description}
  image={image}
  publishDate={publishDate}
  modifiedDate={modifiedDate}
  category={category}
  readTime={readTime}
>
  <div set:html={content} />

  {related.length > 0 && (
    <section class="lg-rel not-prose">
      <h2 class="lg-rel-h">Tips &amp; Trik Lainnya</h2>
      <div class="lg-rel-grid">
        {related.map((p) => (
          <BlogCard title={p.title} slug={p.slug} publishDate={p.publishDate} category={p.category} image={p.image} />
        ))}
      </div>
    </section>
  )}

  <nav class="lg-back not-prose">
    <a href="/berita/" class="lg-back-link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      Kembali ke Tips &amp; Trik
    </a>
  </nav>
</BlogLayout>

<style>
  .lg-rel { margin-top: clamp(3rem, 6vw, 4.5rem); padding-top: clamp(2rem, 4vw, 2.8rem); border-top: 1px solid rgba(26,26,46,.1); }
  .lg-rel-h { font-family:'Inter',sans-serif; font-weight: 800; font-size: clamp(1.35rem, 2.4vw, 1.7rem); letter-spacing: -.02em; color: #1A1A2E; margin: 0 0 1.5rem; }
  .lg-rel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(14.5rem, 1fr)); gap: clamp(1.2rem, 2.5vw, 1.8rem); }
  .lg-back { margin: 2.5rem 0 1rem; }
  .lg-back-link { display: inline-flex; align-items: center; gap: .5rem; font-family:'Inter',sans-serif; font-weight: 700; font-size: .95rem; color: #9A66C2; text-decoration: none; }
  .lg-back-link svg { width: 1.1rem; height: 1.1rem; transition: transform .2s ease; }
  .lg-back-link:hover svg { transform: translateX(-3px); }
</style>
