---
/**
 * Portfolio detail — redirects to the matching item on portfolio.levelgarment.com
 * (the dedicated portfolio site). getStaticPaths keeps every old /portfolio/{slug}
 * URL alive so none 404 at go-live; each forwards to the subdomain's item page.
 */
import portfolioData from '../../data/portfolio.json';

export function getStaticPaths() {
  return portfolioData.items.map((item) => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;
const dest = `https://portfolio.levelgarment.com/portfolio/${slug}/`;
---
<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content={`0;url=${dest}`} />
  <meta name="robots" content="noindex" />
  <link rel="canonical" href={dest} />
  <title>Portfolio — Level Garment</title>
  <script is:inline define:vars={{ dest }}>location.replace(dest)</script>
</head>
<body style="font-family:Inter,sans-serif;padding:3rem;text-align:center">
  <p>Mengarahkan ke <a href={dest}>portfolio</a>…</p>
</body>
</html>
