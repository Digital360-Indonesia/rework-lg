---
/**
 * Portfolio — redirects to the dedicated portfolio site (portfolio.levelgarment.com).
 * The in-repo portfolio pages aren't the polished version, so per Araya we send all
 * /portfolio* traffic to the standalone portfolio subdomain. (Old detail template
 * preserved in git history if we ever bring it back in-house.)
 */
const dest = 'https://portfolio.levelgarment.com/';
---
<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content={`0;url=${dest}`} />
  <meta name="robots" content="noindex" />
  <link rel="canonical" href={dest} />
  <title>Portfolio — Level Garment</title>
  <script is:inline>location.replace('https://portfolio.levelgarment.com/')</script>
</head>
<body style="font-family:Inter,sans-serif;padding:3rem;text-align:center">
  <p>Mengarahkan ke <a href={dest}>portfolio Level Garment</a>…</p>
</body>
</html>
