---
/**
 * Homepage - Level Garment
 *
 * Main landing page showcasing Level Garment's value proposition
 *
 * Sections:
 * - Hero: Main headline and call-to-action
 * - Value Proposition: "Wujudkan Kebersamaan & Kreatifitas" with video gallery
 * - CTA: "Yuk Level Up Acara-mu!" section
 *
 * @version 1.0.0 (CLI 3 Migration Complete)
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
// import ProductCategories from '../components/home/ProductCategories.astro'; // saved (old section-2 carousel) — superseded by ProductRail
import ProductRail from '../components/home/ProductRail.astro';
import VideoBanner from '../components/home/VideoBanner.astro';
import SplitBanner from '../components/home/SplitBanner.astro';
import SponsorshipShowcase from '../components/home/SponsorshipShowcase.astro';
import EndCtaMedia from '../components/home/EndCtaMedia.astro';
import siteConfig from '../data/site-config.json';
import home from '../data/home.json';

// Page metadata
const pageTitle = siteConfig.seo.defaultTitle;
const pageDescription = siteConfig.seo.defaultDescription;
const ogImage = '/assets/images/logo/logo-colored.webp';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={ogImage}
>
  <!-- Hero Section -->
  <Hero variant="default" />

  <!-- Section 2 — editorial product rail (replaces old ProductCategories carousel) -->
  <ProductRail />

  <!-- Video banner -->
  <VideoBanner />

  <!-- Split banner (static left + sliding right) -->
  <SplitBanner />

  <!-- Sponsorship + End CTA share ONE continuous background (sky on top → rooftop/models on bottom) -->
  <div class="lg-duo" style={`background-image: url('${home.duoBackground}')`}>
    <SponsorshipShowcase />
    <EndCtaMedia />
  </div>
</BaseLayout>

<style>
  /* Sponsorship + End CTA: one shared background image spanning both (sky → rooftop).
     full-width so the models at the edges stay in frame; bottom-anchored to keep them. */
  .lg-duo {
    position: relative;
    /* background-image set inline from home.json → duoBackground (CMS-editable) */
    background-size: cover;
    background-position: center bottom;
    background-repeat: no-repeat;
    background-color: #C6A4E6;
  }

  /* Smooth scrolling for anchor links */
  html {
    scroll-behavior: smooth;
  }

  /* Section spacing adjustments */
  :global(section) {
    scroll-margin-top: 80px; /* Account for fixed header */
  }

  /* Prevent layout shift */
  main {
    min-height: 100vh;
  }

  /* ============ MOBILE (phones ≤767px): TikTok / Reels-style full-screen swipe feed ============
     Native CSS scroll-snap — each section is a full-screen panel; swipe up/down snaps one at a time. */
  @media (max-width: 767px) {
    :global(html) { scroll-snap-type: y mandatory; }
    :global(.lg-hero),
    :global(.lg-rail),
    :global(.lg-banner),
    :global(.lg-spon),
    :global(.lg-mcta) {
      height: 100svh !important;
      min-height: 100svh !important;
      margin: 0 !important;
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
    /* Section 4 (split banner) skipped on mobile for now */
    :global(.lg-split) { display: none !important; }
    /* No shared connected background on mobile — Sponsorship + End-CTA become their own full-screen panels */
    .lg-duo { display: contents; }
  }
</style>
