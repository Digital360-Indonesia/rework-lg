---
/**
 * Homepage - Level Garment
 *
 * Main landing page showcasing Level Garment's value proposition
 *
 * Sections:
 * - Hero: Main headline and call-to-action
 * - Value Proposition: "Wujudkan Kebersamaan & Kreatifitas" with video gallery
 * - CTA: "Yuk Level Up Acara-mu!" section
 *
 * @version 1.0.0 (CLI 3 Migration Complete)
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
// import ProductCategories from '../components/home/ProductCategories.astro'; // saved (old section-2 carousel) — superseded by ProductRail
import ProductRail from '../components/home/ProductRail.astro';
import VideoBanner from '../components/home/VideoBanner.astro';
import SplitBanner from '../components/home/SplitBanner.astro';
import SponsorshipShowcase from '../components/home/SponsorshipShowcase.astro';
import EndCtaMedia from '../components/home/EndCtaMedia.astro';
import siteConfig from '../data/site-config.json';
import home from '../data/home.json';

// Page metadata
const pageTitle = siteConfig.seo.defaultTitle;
const pageDescription = siteConfig.seo.defaultDescription;
const ogImage = '/assets/images/logo/logo-colored.webp';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={ogImage}
>
  <!-- Hero Section -->
  <Hero variant="default" />

  <!-- Section 2 — editorial product rail (replaces old ProductCategories carousel) -->
  <ProductRail />

  <!-- Video banner -->
  <VideoBanner />

  {/* Split banner (static left + sliding right) — HIDDEN for now (Araya) on desktop + mobile */}
  {/* <SplitBanner /> */}

  <!-- Sponsorship + End CTA share ONE continuous background (sky on top → rooftop/models on bottom) -->
  <!-- Sponsorship — standalone (own background) -->
  <SponsorshipShowcase />

  <!-- End CTA — plain white, standalone -->
  <EndCtaMedia />

  <script is:inline>document.documentElement.classList.add('lg-home');</script>
</BaseLayout>

<style>
  /* Sponsorship + End CTA: one shared background image spanning both (sky → rooftop).
     full-width so the models at the edges stay in frame; bottom-anchored to keep them. */
  .lg-duo {
    position: relative;
    /* background-image set inline from home.json → duoBackground (CMS-editable) */
    background-size: cover;
    background-position: center bottom;
    background-repeat: no-repeat;
    background-color: #C6A4E6;
  }

  /* Smooth scrolling for anchor links */
  html {
    scroll-behavior: smooth;
  }

  /* Section spacing adjustments */
  :global(section) {
    scroll-margin-top: 80px; /* Account for fixed header */
  }

  /* Prevent layout shift */
  main {
    min-height: 100vh;
  }

  /* ============ MOBILE (phones ≤767px): TikTok / Reels-style full-screen swipe feed ============
     Native CSS scroll-snap — each section is a full-screen panel; swipe up/down snaps one at a time. */
  @media (max-width: 767px) {
    /* TikTok-feel snap: make BODY the single full-screen snap scroller.
       iOS Safari ignores scroll-snap-type on <html> when body has overflow-x:hidden (it shifts the
       scroll container to <body>) → snap silently dies and you get free web-scroll. Locking <html>
       and making <body> the fixed-height snap scroller is the robust cross-engine fix. */
    :global(html.lg-home) { height: var(--app-vh, 100dvh); overflow: hidden; }
    :global(html.lg-home body) { height: var(--app-vh, 100dvh); overflow-x: hidden; overflow-y: scroll; -webkit-overflow-scrolling: touch;
      scroll-snap-type: y mandatory; overscroll-behavior-y: contain; scroll-behavior: auto; }
    /* kill the 80px desktop-header scroll offset so each panel snaps FLUSH (one swipe = full fit, TikTok-style) */
    :global(section) { scroll-margin-top: 0 !important; }
    /* Top header + announcement are hidden on mobile (BaseLayout) — the purple bottom nav (MobileNav) is the navigator. */
    :global(.lg-hero),
    :global(.lg-rail),
    :global(.lg-banner),
    :global(.lg-spon),
    :global(.lg-mcta) {
      height: var(--app-vh, 100dvh) !important;   /* JS-pinned to real viewport (fallback dvh) — fills exactly, last panel reachable */
      min-height: var(--app-vh, 100dvh) !important;
      margin: 0 !important;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      /* Suppress iOS long-press preview (the "zoom on hold") + double-tap-to-zoom on the reels feed.
         touch-action:manipulation keeps panning + pinch-zoom (a11y) but kills the double-tap gesture. */
      -webkit-touch-callout: none; -webkit-user-select: none; user-select: none;
      -webkit-tap-highlight-color: transparent; touch-action: manipulation;
    }
    /* Section 4 (split banner) skipped on mobile for now */
    :global(.lg-split) { display: none !important; }
    /* No shared connected background on mobile — Sponsorship + End-CTA become their own full-screen panels */
    .lg-duo { display: contents; }
  }
</style>
