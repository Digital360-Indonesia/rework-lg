---
/**
 * Katalog Jersey Baseball - Level Garment
 *
 * Page untuk menampilkan katalog jersey baseball dalam format PDF
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../data/site-config.json';

const pageTitle = 'Katalog Jersey Baseball';
const pageDescription = 'Lihat katalog lengkap jersey baseball dari Level Garment. Tersedia berbagai desain dan ukuran untuk tim Anda.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
>
  <div class="min-h-screen bg-gray-50 py-12">
    <div class="container mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Katalog Jersey Baseball
        </h1>
        <p class="text-lg text-gray-600">
          Temukan berbagai pilihan jersey baseball berkualitas untuk tim Anda
        </p>
      </div>

      <!-- PDF Viewer -->
      <div class="bg-white rounded-lg shadow-lg overflow-hidden">
        <div class="w-full" style="height: 800px;">
          <embed
            src="/katalog-jersey-level.pdf"
            type="application/pdf"
            width="100%"
            height="100%"
            class="border-0"
          />
        </div>
      </div>

      <!-- Fallback for browsers without PDF support -->
      <noscript>
        <div class="mt-8 text-center">
          <p class="text-gray-600 mb-4">
            Browser Anda tidak mendukung tampilan PDF langsung.
          </p>
          <a
            href="/katalog-jersey-level.pdf"
            download
            class="inline-block bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-dark transition-colors"
          >
            Download Katalog PDF
          </a>
        </div>
      </noscript>

      <!-- Download Button -->
      <div class="mt-8 text-center">
        <a
          href="/katalog-jersey-level.pdf"
          download
          class="inline-block bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary-dark transition-colors"
        >
          Download Katalog PDF
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  embed {
    display: block;
  }
</style>
