---
/**
 * Promo — temporarily redirects to WhatsApp (per Araya). Current promos are shared
 * via chat for now; build a real promo page later. (Old promo page in git history.)
 */
import siteConfig from '../../data/site-config.json';
const wa = (siteConfig as any).contact?.whatsapp || '6285183091599';
const dest = `https://wa.me/${wa}?text=` + encodeURIComponent('Halo Level Garment, aku mau tanya promo yang lagi berjalan. Boleh info?');
---
<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content={`0;url=${dest}`} />
  <meta name="robots" content="noindex" />
  <link rel="canonical" href={dest} />
  <title>Promo — Level Garment</title>
  <script is:inline define:vars={{ dest }}>location.replace(dest)</script>
</head>
<body style="font-family:Inter,sans-serif;padding:3rem;text-align:center;background:#1A1A2E;color:#fff">
  <p>Mengarahkan ke <a href={dest} style="color:#AF7AD5">WhatsApp Level Garment</a>…</p>
</body>
</html>
