---
/**
 * Product — temporarily redirects to WhatsApp. Our product/catalog pages aren't
 * polished for go-live yet, so per Araya all /product traffic goes to WA chat for
 * now; we'll build the real catalog later. (Old browse page kept in git history.)
 */
import siteConfig from '../../data/site-config.json';
const wa = (siteConfig as any).contact?.whatsapp || '6285183091599';
const dest = `https://wa.me/${wa}?text=` + encodeURIComponent('Halo Level Garment, aku mau pesan produk custom. Boleh info katalog & harga?');
---
<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content={`0;url=${dest}`} />
  <meta name="robots" content="noindex" />
  <link rel="canonical" href={dest} />
  <title>Produk — Level Garment</title>
  <script is:inline define:vars={{ dest }}>location.replace(dest)</script>
</head>
<body style="font-family:Inter,sans-serif;padding:3rem;text-align:center;background:#1A1A2E;color:#fff">
  <p>Mengarahkan ke <a href={dest} style="color:#AF7AD5">WhatsApp Level Garment</a>…</p>
</body>
</html>
