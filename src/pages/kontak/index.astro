---
/**
 * Kontak — Level Garment. Branded contact page: WhatsApp-first, email, address +
 * interactive map, jam operasional, socials. Responsive (desktop 2-col / mobile stack).
 */
import PageLayout from '../../layouts/PageLayout.astro';
import siteConfig from '../../data/site-config.json';
import home from '../../data/home.json';
const { contact, social } = siteConfig as any;
const waChat = `https://wa.me/${contact.whatsapp}?text=` + encodeURIComponent('Halo Level Garment, aku mau konsultasi & pesan custom buat acara/kelas. Boleh info?');
const addr = contact.address || 'Level Garment Surabaya';
const mapsUrl = 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(addr);
const mapEmbed = 'https://maps.google.com/maps?q=' + encodeURIComponent(addr) + '&z=15&output=embed';
const hours = (home as any).endCta?.hours || [{ day: 'Senin – Sabtu', time: '08.00 – 17.00 WIB' }, { day: 'Minggu & Libur', time: 'Tutup' }];
const WA = 'M.06 24l1.69-6.16a11.86 11.86 0 0 1-1.59-5.95C.16 5.34 5.5 0 12.06 0a11.82 11.82 0 0 1 8.41 3.49 11.82 11.82 0 0 1 3.48 8.42c0 6.55-5.34 11.89-11.9 11.89a11.9 11.9 0 0 1-5.68-1.45L.06 24Zm6.6-3.8c1.68.99 3.28 1.59 5.4 1.59 5.45 0 9.89-4.43 9.89-9.88a9.86 9.86 0 0 0-9.88-9.89C6.6 2.02 2.16 6.45 2.16 11.9c0 2.23.65 3.9 1.74 5.65l-1 3.65 3.76-.99ZM17.42 14.5c-.07-.12-.27-.2-.56-.34-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.64.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.76-1.64-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.21-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.22 3.08.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.42.25-.69.25-1.29.18-1.41Z';
const socials = [
  { name: 'Instagram', url: social?.instagram, d: 'M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.15-3.23 1.66-4.77 4.92-4.92C8.42 2.17 8.8 2.16 12 2.16Zm0 3.68A6.16 6.16 0 1 0 18.16 12 6.16 6.16 0 0 0 12 5.84Zm0 10.16A4 4 0 1 1 16 12a4 4 0 0 1-4 4Zm6.4-10.4a1.44 1.44 0 1 0 1.44 1.44 1.44 1.44 0 0 0-1.44-1.44Z' },
  { name: 'TikTok', url: social?.tiktok, d: 'M16.5 3c.3 2.1 1.5 3.6 3.5 3.8v2.5c-1.3.1-2.5-.3-3.5-1v6.4c0 3.4-2.7 5.8-5.9 5.3-2.4-.4-4.1-2.4-4.1-4.9 0-3.1 2.9-5.4 6-4.7v2.7c-.4-.1-.9-.2-1.4-.1-1.1.1-2 1-2 2.2 0 1.3 1.1 2.3 2.4 2.1 1.1-.2 1.9-1.2 1.9-2.4V3h2.6Z' },
  { name: 'Facebook', url: social?.facebook, d: 'M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12Z' },
  { name: 'YouTube', url: social?.youtube, d: 'M23 12s0-3.2-.4-4.7a2.5 2.5 0 0 0-1.77-1.77C19.32 5.1 12 5.1 12 5.1s-7.32 0-8.83.43A2.5 2.5 0 0 0 1.4 7.3C1 8.8 1 12 1 12s0 3.2.4 4.7a2.5 2.5 0 0 0 1.77 1.77C4.68 18.9 12 18.9 12 18.9s7.32 0 8.83-.43a2.5 2.5 0 0 0 1.77-1.77C23 15.2 23 12 23 12Zm-13.2 3.02V8.98L15.5 12l-5.7 3.02Z' },
].filter((s) => s.url);
---
<PageLayout
  title="Kontak - Level Garment"
  description="Hubungi Level Garment untuk konsultasi gratis & pemesanan jersey, jaket, dan kaos custom."
  showHero={false}
>
  <section class="lg-kontak">
    <div class="lg-k-wrap">
      <div class="lg-k-grid">
        <!-- details -->
        <div class="lg-k-info">
          <h2 class="lg-k-h">Langsung Terhubung</h2>

          <a class="lg-k-card lg-k-wa" href={waChat} target="_blank" rel="noopener noreferrer">
            <span class="lg-k-ico is-wa"><svg viewBox="0 0 24 24" fill="currentColor"><path d={WA}/></svg></span>
            <span class="lg-k-txt"><strong>WhatsApp</strong><em>{contact.phoneFormatted} · chat & pesan langsung</em></span>
            <svg class="lg-k-arr" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>

          <a class="lg-k-card" href={`mailto:${contact.email}`}>
            <span class="lg-k-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></span>
            <span class="lg-k-txt"><strong>Email</strong><em>{contact.email}</em></span>
          </a>

          <a class="lg-k-card" href={mapsUrl} target="_blank" rel="noopener noreferrer">
            <span class="lg-k-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg></span>
            <span class="lg-k-txt"><strong>Alamat Workshop</strong><em>{addr}</em></span>
          </a>

          <div class="lg-k-hours">
            <strong>Jam Operasional</strong>
            <ul>{hours.map((h: any) => (<li><span>{h.day}</span><span>{h.time}</span></li>))}</ul>
          </div>

          {socials.length > 0 && (
            <div class="lg-k-social">
              <strong>Ikuti Kami</strong>
              <div class="lg-k-soc-row">
                {socials.map((s) => (
                  <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.name}><svg viewBox="0 0 24 24" fill="currentColor"><path d={s.d}/></svg></a>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- map + CTA -->
        <div class="lg-k-side">
          <div class="lg-k-map">
            <iframe src={mapEmbed} title="Lokasi Level Garment" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
          </div>
          <a class="lg-k-cta" href={waChat} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d={WA}/></svg>
            Mulai Konsultasi di WhatsApp
          </a>
          <p class="lg-k-note">Balasan cepat di jam kerja. Custom buat angkatan, kelas, organisasi — tanpa minimal order.</p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .lg-kontak { background: #f7f4fb; padding: clamp(2.5rem, 6vw, 5rem) 0; }
  .lg-k-wrap { max-width: 64rem; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 2rem); }
  .lg-k-grid { display: grid; grid-template-columns: 1fr; gap: clamp(1.5rem, 4vw, 2.5rem); }
  @media (min-width: 880px) { .lg-k-grid { grid-template-columns: 1fr 1fr; align-items: start; } }

  .lg-k-h { font-family:'Inter',sans-serif; font-weight: 800; font-size: clamp(1.3rem, 2.4vw, 1.7rem); color:#1A1A2E; letter-spacing:-.02em; margin: 0 0 1.1rem; }

  .lg-k-card { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.1rem; margin-bottom: .8rem;
    background:#fff; border:1px solid rgba(26,26,46,.09); border-radius: 1rem; text-decoration:none; color:#1A1A2E;
    box-shadow: 0 6px 20px -16px rgba(26,26,46,.4); transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease; }
  @media (hover:hover){ .lg-k-card:hover { transform: translateY(-2px); border-color: rgba(175,122,213,.6); box-shadow: 0 14px 30px -18px rgba(70,35,110,.5); } }
  .lg-k-ico { flex:0 0 auto; width: 2.9rem; height: 2.9rem; display:grid; place-items:center; border-radius: 999px;
    background: rgba(175,122,213,.14); color:#9A66C2; }
  .lg-k-ico svg { width: 1.4rem; height: 1.4rem; }
  .lg-k-ico.is-wa { background: rgba(37,211,102,.16); color:#1faa52; }
  .lg-k-txt { display:flex; flex-direction:column; gap:.15rem; min-width:0; }
  .lg-k-txt strong { font-family:'Inter',sans-serif; font-weight:700; font-size:1rem; }
  .lg-k-txt em { font-style: normal; font-size:.9rem; color:#5a5a6e; line-height:1.35; word-break: break-word; }
  .lg-k-arr { width:1.2rem; height:1.2rem; margin-left:auto; color:#1faa52; flex:0 0 auto; }
  .lg-k-wa { border-color: rgba(37,211,102,.35); background: linear-gradient(180deg,#fff, #f3fbf6); }

  .lg-k-hours { margin-top: 1.4rem; padding: 1.1rem 1.2rem; background:#fff; border:1px solid rgba(26,26,46,.09); border-radius:1rem; }
  .lg-k-hours strong { display:block; font-family:'Inter',sans-serif; font-weight:700; color:#1A1A2E; margin-bottom:.6rem; }
  .lg-k-hours ul { list-style:none; margin:0; padding:0; }
  .lg-k-hours li { display:flex; justify-content:space-between; gap:1rem; padding:.45rem 0; border-bottom:1px solid rgba(26,26,46,.07); font-size:.93rem; color:#3a3a4c; }
  .lg-k-hours li:last-child { border-bottom:0; }

  .lg-k-social { margin-top:1.4rem; }
  .lg-k-social strong { display:block; font-family:'Inter',sans-serif; font-weight:700; color:#1A1A2E; margin-bottom:.7rem; }
  .lg-k-soc-row { display:flex; gap:.6rem; }
  .lg-k-soc-row a { width:2.6rem; height:2.6rem; display:grid; place-items:center; border-radius:999px; background:#fff; border:1px solid rgba(26,26,46,.1); color:#1A1A2E; transition: background .2s ease, color .2s ease, transform .2s ease; }
  .lg-k-soc-row a svg { width:1.25rem; height:1.25rem; }
  @media (hover:hover){ .lg-k-soc-row a:hover { background:#9A66C2; color:#fff; transform: translateY(-2px); } }

  .lg-k-side { position: sticky; top: 6rem; }
  @media (max-width: 879px){ .lg-k-side { position: static; } }
  .lg-k-map { width:100%; aspect-ratio: 4/3; border-radius:1.1rem; overflow:hidden; border:1px solid rgba(26,26,46,.12); box-shadow: 0 18px 40px -24px rgba(26,26,46,.5); }
  .lg-k-map iframe { width:100%; height:100%; border:0; display:block; }
  .lg-k-cta { display:flex; align-items:center; justify-content:center; gap:.6rem; margin-top:1rem; padding:1rem 1.2rem; border-radius:999px;
    background:#25d366; color:#fff; font-family:'Inter',sans-serif; font-weight:700; font-size:1.02rem; text-decoration:none;
    box-shadow: 0 12px 26px -12px rgba(37,211,102,.6); transition: transform .2s ease, background .2s ease; }
  .lg-k-cta svg { width:1.4rem; height:1.4rem; }
  @media (hover:hover){ .lg-k-cta:hover { transform: translateY(-2px); background:#1fbe5b; } }
  .lg-k-note { margin:.9rem 0 0; font-size:.85rem; color:#6a6a7c; line-height:1.5; text-align:center; }
</style>
