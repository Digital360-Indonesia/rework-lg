---
/**
 * Blog (Tips & Trik) article layout — clean editorial: light header (breadcrumb,
 * category, title, meta), a contained featured image, premium prose, share row, CTA.
 */
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  author?: string;
  publishDate?: string;
  modifiedDate?: string;
  category?: string;
  readTime?: number;
}
const {
  title, description, image,
  author = 'Level Garment',
  publishDate = new Date().toISOString(),
  modifiedDate, category = 'Tips', readTime = 5,
} = Astro.props;

const formatDate = (d: string) => new Date(d).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
const url = Astro.url.toString();
const WA = 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347';
---
<BaseLayout title={title} description={description} image={image} type="article" publishedTime={publishDate} modifiedTime={modifiedDate}>
  <article class="lg-art">
    <header class="lg-art-head">
      <nav class="lg-art-crumb" aria-label="Breadcrumb">
        <a href="/">Beranda</a><span>/</span><a href="/berita/">Tips &amp; Trik</a><span>/</span><span class="lg-art-crumb-cur">{category}</span>
      </nav>
      <span class="lg-art-cat">{category}</span>
      <h1 class="lg-art-title">{title}</h1>
      <div class="lg-art-meta">
        <span class="lg-art-author">{author}</span>
        <span class="lg-art-dot">•</span>
        <time datetime={publishDate}>{formatDate(publishDate)}</time>
        <span class="lg-art-dot">•</span>
        <span>{readTime} menit baca</span>
      </div>
    </header>

    {image && (
      <figure class="lg-art-hero">
        <img src={image} alt={title} loading="eager" />
      </figure>
    )}

    <div class="lg-art-wrap">
      <div class="blog-post-content">
        <slot />
      </div>

      <div class="lg-art-share">
        <span class="lg-art-share-label">Bagikan artikel</span>
        <div class="lg-art-share-btns">
          <a href={`https://wa.me/?text=${encodeURIComponent(title + ' ' + url)}`} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="is-wa"><svg viewBox="0 0 24 24" fill="currentColor"><path d={WA}/></svg></a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`} target="_blank" rel="noopener noreferrer" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
          <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
          <button type="button" data-copy aria-label="Salin tautan"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg></button>
        </div>
      </div>
    </div>

    <section class="lg-art-cta">
      <h2>Mau bikin custom untuk tim atau komunitasmu?</h2>
      <p>Konsultasi gratis &amp; penawaran terbaik — jaket, jersey, kaos, semua bisa custom.</p>
      <a href={`https://wa.me/6285183091599?text=${encodeURIComponent('Halo Level Garment, aku mau konsultasi custom apparel. Boleh info?')}`} target="_blank" rel="noopener noreferrer" class="lg-art-cta-btn">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d={WA}/></svg> Konsultasi WhatsApp
      </a>
    </section>
  </article>
</BaseLayout>

<style>
  .lg-art { background: #fff; }
  .lg-art-head { max-width: 44rem; margin: 0 auto; padding: clamp(2.5rem, 6vw, 4rem) clamp(1.25rem, 5vw, 2rem) clamp(1.5rem, 3vw, 2rem); text-align: center; }
  .lg-art-crumb { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: .5rem; font-family:'Inter',sans-serif; font-size: .8rem; color: #8a8a9c; margin-bottom: 1.3rem; }
  .lg-art-crumb a { color: #8a8a9c; text-decoration: none; transition: color .2s ease; }
  .lg-art-crumb a:hover { color: #9A66C2; }
  .lg-art-crumb-cur { color: #1A1A2E; font-weight: 600; }
  .lg-art-cat { display: inline-block; font-family:'Inter',sans-serif; font-weight: 700; font-size: .68rem; letter-spacing: .12em; text-transform: uppercase; color: #9A66C2; background: rgba(175,122,213,.13); padding: .35rem .8rem; border-radius: 999px; margin-bottom: 1.1rem; }
  .lg-art-title { font-family:'Inter',sans-serif; font-weight: 800; font-size: clamp(1.8rem, 4.5vw, 2.9rem); line-height: 1.12; letter-spacing: -.02em; color: #1A1A2E; margin: 0 0 1.2rem; }
  .lg-art-meta { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: .55rem; font-family:'Inter',sans-serif; font-size: .9rem; color: #6a6a7c; }
  .lg-art-author { font-weight: 600; color: #1A1A2E; }
  .lg-art-dot { color: #c7c7d2; }

  .lg-art-hero { max-width: 56rem; margin: 0 auto clamp(2rem, 4vw, 3rem); padding: 0 clamp(1.25rem, 5vw, 2rem); }
  .lg-art-hero img { width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 1.1rem; display: block; box-shadow: 0 28px 56px -34px rgba(26,26,46,.55); }

  .lg-art-wrap { max-width: 44rem; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 2rem); }

  /* ---- premium prose ---- */
  .blog-post-content { color: #2c2c3a; font-family:'Inter',sans-serif; font-size: clamp(1.02rem, 1.4vw, 1.13rem); line-height: 1.8; }
  .blog-post-content :where(h2):not(:where([class~="not-prose"] *)) { font-family:'Inter',sans-serif; font-weight: 800; font-size: 1.6rem; line-height: 1.25; letter-spacing: -.01em; color: #1A1A2E; margin: 2.4rem 0 1rem; }
  .blog-post-content :where(h3):not(:where([class~="not-prose"] *)) { font-family:'Inter',sans-serif; font-weight: 700; font-size: 1.3rem; line-height: 1.3; color: #1A1A2E; margin: 2rem 0 .8rem; }
  .blog-post-content :where(h4):not(:where([class~="not-prose"] *)) { font-weight: 700; font-size: 1.12rem; color: #1A1A2E; margin: 1.6rem 0 .6rem; }
  .blog-post-content :where(p):not(:where([class~="not-prose"] *)) { margin: 0 0 1.35rem; }
  .blog-post-content :where(a):not(:where([class~="not-prose"] *)) { color: #9A66C2; text-decoration: underline; text-underline-offset: 2px; font-weight: 500; }
  .blog-post-content :where(strong):not(:where([class~="not-prose"] *)) { color: #1A1A2E; font-weight: 700; }
  .blog-post-content :where(img):not(:where([class~="not-prose"] *)) { width: 100%; border-radius: .8rem; margin: 1.8rem 0; display: block; }
  .blog-post-content :where(ul, ol):not(:where([class~="not-prose"] *)) { margin: 0 0 1.35rem; padding-left: 1.4rem; }
  .blog-post-content :where(ul):not(:where([class~="not-prose"] *)) { list-style: disc; }
  .blog-post-content :where(ol):not(:where([class~="not-prose"] *)) { list-style: decimal; }
  .blog-post-content :where(li):not(:where([class~="not-prose"] *)) { margin: .45rem 0; padding-left: .2rem; }
  .blog-post-content :where(li)::marker { color: #AF7AD5; }
  .blog-post-content :where(blockquote):not(:where([class~="not-prose"] *)) { border-left: 3px solid #AF7AD5; padding: .2rem 0 .2rem 1.3rem; margin: 1.8rem 0; color: #5a5a6e; font-style: italic; font-size: 1.1em; }
  .blog-post-content :where(h2, h3):first-child { margin-top: 0; }

  /* ---- share ---- */
  .lg-art-share { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; margin: clamp(2rem, 4vw, 3rem) 0 0; padding-top: 1.6rem; border-top: 1px solid rgba(26,26,46,.1); }
  .lg-art-share-label { font-family:'Inter',sans-serif; font-weight: 700; font-size: .95rem; color: #1A1A2E; }
  .lg-art-share-btns { display: flex; gap: .6rem; }
  .lg-art-share-btns a, .lg-art-share-btns button { width: 2.5rem; height: 2.5rem; border-radius: 999px; display: grid; place-items: center; background: #f2eef8; color: #6a4a8c; border: 0; cursor: pointer; transition: transform .2s ease, background .2s ease, color .2s ease; }
  .lg-art-share-btns a svg, .lg-art-share-btns button svg { width: 1.15rem; height: 1.15rem; }
  .lg-art-share-btns a:hover, .lg-art-share-btns button:hover { transform: translateY(-2px); background: #9A66C2; color: #fff; }
  .lg-art-share-btns .is-wa:hover { background: #25d366; }

  /* ---- CTA ---- */
  .lg-art-cta { max-width: 50rem; margin: clamp(3rem, 6vw, 4.5rem) auto 0; padding: clamp(2.2rem, 5vw, 3.2rem) clamp(1.5rem, 5vw, 2rem); text-align: center; background: linear-gradient(160deg, #2a1a45, #1A1A2E); border-radius: 1.4rem; }
  @media (min-width: 768px) { .lg-art-cta { margin-bottom: 3rem; } }
  .lg-art-cta h2 { margin: 0 0 .7rem; font-family:'Inter',sans-serif; font-weight: 800; font-size: clamp(1.4rem, 2.6vw, 1.9rem); line-height: 1.2; color: #fff; }
  .lg-art-cta p { margin: 0 auto 1.6rem; max-width: 34rem; font-family:'Inter',sans-serif; font-size: 1rem; line-height: 1.5; color: rgba(255,255,255,.82); }
  .lg-art-cta-btn { display: inline-flex; align-items: center; gap: .55rem; padding: .95rem 1.7rem; border-radius: 999px; background: #25d366; color: #fff; font-family:'Inter',sans-serif; font-weight: 700; font-size: 1rem; text-decoration: none; box-shadow: 0 14px 30px -12px rgba(37,211,102,.55); transition: transform .2s ease, background .2s ease; }
  .lg-art-cta-btn svg { width: 1.3rem; height: 1.3rem; }
  .lg-art-cta-btn:hover { transform: translateY(-2px); background: #1fbe5b; }

  /* related/back that [slug] injects after the content — give them room + max-width */
  .lg-art-wrap :global(.related-posts), .lg-art-wrap :global(.back-to-blog) { margin-top: 2.5rem; }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(window.location.href); btn.classList.add('copied'); setTimeout(() => btn.classList.remove('copied'), 1500); } catch {}
    });
  });
</script>
