---
/**
 * Base Layout - Level Garment
 * Main layout wrapper for all pages
 */
import AnnouncementBar from '../components/layout/AnnouncementBar.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MobileNav from '../components/layout/MobileNav.astro';
import siteConfig from '../data/site-config.json';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  canonicalURL?: string;
}

const {
  title,
  description = siteConfig.description,
  image = '/assets/images/og-image.png',
  noIndex = false,
  type = 'website',
  publishedTime,
  modifiedTime,
  canonicalURL,
} = Astro.props;

// Generate canonical URL
const fullCanonicalURL = canonicalURL
  ? new URL(canonicalURL, siteConfig.siteUrl)
  : new URL(Astro.url.pathname, siteConfig.siteUrl);

// Page type for structured data
const pageType = type === 'article' ? 'article' : 'website';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="generator" content={Astro.generator}>
  <!-- mark JS-capable ASAP so the smooth media-reveal (.lg-rv) only hides media when it can fade it back in -->
  <script is:inline>document.documentElement.classList.add('lg-js');</script>
  <!-- Pin --app-vh to the REAL viewport height. The mobile reels feed makes <body> the snap scroller,
       which changes how iOS/Android size 100dvh under the browser toolbar — leaving the last panel
       able to under-scroll (not full-screen). Measuring window.innerHeight and driving panel height
       off it fills each panel to the actual visible area. Updated only on orientation/size change
       (not per-scroll) to avoid mid-scroll reflow. -->
  <script is:inline>
    (function () {
      var set = function () { document.documentElement.style.setProperty('--app-vh', window.innerHeight + 'px'); };
      set();
      addEventListener('orientationchange', function () { setTimeout(set, 250); });
      addEventListener('resize', function () {
        // only react to real viewport changes (rotate / window resize), ignore the tiny
        // toolbar-driven deltas that fire during scroll
        clearTimeout(window.__avhT); window.__avhT = setTimeout(set, 200);
      });
    })();
  </script>

  <!-- SEO Meta Tags -->
  <title>{title} - {siteConfig.siteName}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={fullCanonicalURL}>

  {noIndex && <meta name="robots" content="noindex, nofollow">}

  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-TRWBR2PB');</script>
  <!-- End Google Tag Manager -->

  <!-- Google tag (gtag.js) -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-Y6F1B63N48"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-Y6F1B63N48');
  </script>

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={pageType}>
  <meta property="og:url" content={fullCanonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={new URL(image, siteConfig.siteUrl)}>
  <meta property="og:site_name" content={siteConfig.siteName}>
  <meta property="og:locale" content="id_ID">

  {publishedTime && <meta property="article:published_time" content={publishedTime}>}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime}>}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content={fullCanonicalURL}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={new URL(image, siteConfig.siteUrl)}>

  <!-- Favicon - from levelgarment.com -->
  <link rel="icon" type="image/png" sizes="196x196" href="/favicon.png">
  <link rel="icon" type="image/png" sizes="196x196" href="/07062024-lg-favicon.png">
  <link rel="apple-touch-icon" sizes="196x196" href="/favicon.png">
  <link rel="apple-touch-icon" sizes="196x196" href="/07062024-lg-favicon.png">

  <!-- Fonts - matches live site levelgarment.com (Poppins, Inter, Montserrat, Roboto) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Montserrat:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&family=Roboto:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Structured Data -->
  <script set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": type === 'article' ? 'Article' : 'WebPage',
    "name": title,
    "description": description,
    "url": fullCanonicalURL,
    "publisher": {
      "@type": "Organization",
      "name": siteConfig.siteName,
      "url": siteConfig.siteUrl,
      "logo": {
        "@type": "ImageObject",
        "url": new URL('/assets/images/logo.png', siteConfig.siteUrl)
      },
      "sameAs": [
        siteConfig.social.instagram,
        siteConfig.social.tiktok
      ]
    },
    ...(type === 'article' && {
      "headline": title,
      "datePublished": publishedTime,
      "dateModified": modifiedTime
    })
  })} type="application/ld+json"></script>
</head>

<body class="min-h-screen flex flex-col">
  <!-- Skip to main content for accessibility -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-primary text-white px-4 py-2 rounded-lg z-50">
    Skip to main content
  </a>

  <!-- Announcement ticker + Header / Navigation -->
  <AnnouncementBar />
  <Header />

  <!-- Main Content -->
  <main id="main-content" class="flex-grow">
    <slot />
  </main>

  <!-- Footer -->
  <Footer />

  <!-- Mobile bottom navigation (phones only) — replaces the top header/hamburger on mobile -->
  <MobileNav />

  <!-- Smooth media reveal: fade each .lg-rv element in once it's truly ready, and clear the
       shimmer on its placeholder container. Keeps loading consistent + "knowable" sitewide. -->
  <script is:inline>
    (function () {
      var ready = function (el) {
        el.classList.add('is-ready');
        var c = el.closest('.lg-skel');
        if (c) c.classList.add('is-ready');
      };
      var arm = function (el) {
        if (el.dataset.rvArmed) return; el.dataset.rvArmed = '1';
        if (el.tagName === 'IMG') {
          if (el.complete && el.naturalWidth > 0) ready(el);
          else { el.addEventListener('load', function () { ready(el); }, { once: true });
                 el.addEventListener('error', function () { ready(el); }, { once: true }); }
        } else { // video
          var on = function () { ready(el); };
          if (el.readyState >= 3 && !el.paused) on();
          el.addEventListener('playing', on, { once: true });
          el.addEventListener('loadeddata', function () { if (el.readyState >= 2 && !el.paused) on(); });
        }
      };
      var scan = function () { document.querySelectorAll('.lg-rv').forEach(arm); };
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', scan);
      else scan();
      // catch media that mounts/plays later (lazy reels, carousel clones)
      new MutationObserver(scan).observe(document.body, { childList: true, subtree: true });
    })();
  </script>
</body>
</html>

<style>
  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .focus\:not-sr-only:focus {
    position: static;
    width: auto;
    height: auto;
    padding: inherit;
    margin: inherit;
    overflow: visible;
    clip: auto;
    white-space: normal;
  }

  /* ===== MOBILE (≤767px): top header + announcement give way to the bottom nav bar ===== */
  @media (max-width: 767px) {
    :global(.lg-header),
    :global(.lg-ticker) { display: none !important; }
    /* mobile: the bottom nav is the site chrome everywhere — hide the old web footer site-wide */
    :global(.lgf) { display: none !important; }
    /* normal (non-homepage) pages: clear the fixed bottom nav so last content isn't hidden.
       The homepage reels feed is full-screen behind the nav, so it opts out via html.lg-home. */
    main { padding-bottom: calc(3.9rem + env(safe-area-inset-bottom, 0px)); }
    :global(html.lg-home) main { padding-bottom: 0; }
  }
</style>
