---
/**
 * Blog card — Gopuff-style: rounded image on top, gray category eyebrow, bold title, date.
 */
export interface Props {
  title: string;
  slug: string;
  excerpt?: string;
  publishDate: string;
  category?: string;
  image?: string;
}
const { title, slug, publishDate, category = 'Tips', image = '' } = Astro.props;
const formatDate = (d: string) => new Date(d).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
---
<article class="lg-bc">
  <a class="lg-bc-link" href={`/berita/${slug}/`}>
    <div class="lg-bc-img">
      {image ? <img src={image} alt={title} loading="lazy" /> : <div class="lg-bc-ph"></div>}
    </div>
    <div class="lg-bc-body">
      <span class="lg-bc-cat">{category}</span>
      <h3 class="lg-bc-title">{title}</h3>
      <time class="lg-bc-date" datetime={publishDate}>{formatDate(publishDate)}</time>
    </div>
  </a>
</article>

<style>
  .lg-bc { height: 100%; }
  .lg-bc-link { display: flex; flex-direction: column; height: 100%; text-decoration: none; }
  .lg-bc-img { aspect-ratio: 4/3; overflow: hidden; border-radius: 1rem; background: #eee9f3; }
  .lg-bc-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .5s ease; }
  @media (hover:hover){ .lg-bc:hover .lg-bc-img img { transform: scale(1.04); } }
  .lg-bc-ph { width: 100%; height: 100%; background: linear-gradient(135deg,#d8c8ee,#eee9f3); }
  .lg-bc-body { padding: .95rem .15rem 0; display: flex; flex-direction: column; flex: 1; }
  .lg-bc-cat { font-family:'Inter',sans-serif; font-weight: 700; font-size: .68rem; letter-spacing: .12em; text-transform: uppercase; color: #9a8db0; margin-bottom: .5rem; }
  .lg-bc-title { font-family:'Inter',sans-serif; font-weight: 800; font-size: 1.12rem; line-height: 1.28; letter-spacing: -.01em; color: #1A1A2E; margin: 0 0 .55rem;
    display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; transition: color .2s ease; }
  @media (hover:hover){ .lg-bc:hover .lg-bc-title { color: #9A66C2; } }
  .lg-bc-date { margin-top: auto; font-family:'Inter',sans-serif; font-size: .82rem; color: #9a9aa8; }
</style>
