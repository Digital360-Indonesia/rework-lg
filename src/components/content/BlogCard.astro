---
/**
 * Blog Card — clean branded article preview (image, category chip, title, excerpt, date).
 */
export interface Props {
  title: string;
  slug: string;
  excerpt: string;
  publishDate: string;
  category?: string;
  image?: string;
}
const { title, slug, excerpt, publishDate, category = 'Tips', image = '' } = Astro.props;
const formatDate = (d: string) => new Date(d).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
---
<article class="lg-bc">
  <a class="lg-bc-link" href={`/berita/${slug}/`}>
    <div class="lg-bc-img">
      {image ? <img src={image} alt={title} loading="lazy" /> : <div class="lg-bc-ph"></div>}
    </div>
    <div class="lg-bc-body">
      <span class="lg-bc-chip">{category}</span>
      <h3 class="lg-bc-title">{title}</h3>
      <p class="lg-bc-ex">{excerpt}</p>
      <time class="lg-bc-date" datetime={publishDate}>{formatDate(publishDate)}</time>
    </div>
  </a>
</article>

<style>
  .lg-bc { background:#fff; border:1px solid rgba(26,26,46,.08); border-radius:1.1rem; overflow:hidden;
    box-shadow:0 10px 26px -20px rgba(26,26,46,.45); transition: transform .25s ease, box-shadow .25s ease; height:100%; }
  @media (hover:hover){ .lg-bc:hover { transform: translateY(-4px); box-shadow:0 22px 40px -24px rgba(70,35,110,.5); } }
  .lg-bc-link { display:flex; flex-direction:column; height:100%; text-decoration:none; color:#1A1A2E; }
  .lg-bc-img { aspect-ratio: 16/10; overflow:hidden; background:#ece6f3; }
  .lg-bc-img img { width:100%; height:100%; object-fit:cover; display:block; transition: transform .5s ease; }
  @media (hover:hover){ .lg-bc:hover .lg-bc-img img { transform: scale(1.05); } }
  .lg-bc-ph { width:100%; height:100%; background:linear-gradient(135deg,#d8c8ee,#ece6f3); }
  .lg-bc-body { padding:1.1rem 1.15rem 1.3rem; display:flex; flex-direction:column; flex:1; }
  .lg-bc-chip { align-self:flex-start; font-family:'Inter',sans-serif; font-weight:700; font-size:.65rem; letter-spacing:.07em; text-transform:uppercase; color:#9A66C2; background:rgba(175,122,213,.13); padding:.28rem .6rem; border-radius:999px; margin-bottom:.7rem; }
  .lg-bc-title { font-family:'Inter',sans-serif; font-weight:700; font-size:1.05rem; line-height:1.3; letter-spacing:-.01em; margin:0 0 .5rem; color:#1A1A2E;
    display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; transition: color .2s ease; }
  @media (hover:hover){ .lg-bc:hover .lg-bc-title { color:#9A66C2; } }
  .lg-bc-ex { font-family:'Inter',sans-serif; font-size:.88rem; line-height:1.5; color:#5a5a6e; margin:0 0 1rem;
    display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
  .lg-bc-date { margin-top:auto; font-family:'Inter',sans-serif; font-size:.78rem; color:#8a8a9c; font-weight:500; }
</style>
