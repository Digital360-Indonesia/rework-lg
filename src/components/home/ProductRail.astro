---
/**
 * Section 2 — product categories.
 *  • Desktop: editorial rail (PUMA "New & Trending" model) — tall vertical media,
 *    edge-to-edge, small left caption, free horizontal scroll. (Clones hidden.)
 *  • Mobile (≤767px): full-screen "IG Edits" panel — bold head + lighter subhead,
 *    big portrait rounded card with left/right peek + center emphasis, INFINITE
 *    LOOP (clone of last before first + clone of first after last → wraps both
 *    ways), each card carries an icon-circle + name (+ star badge for featured),
 *    over a blurred purple-tinted backdrop that follows the centered card.
 */
import home from '../../data/home.json';
const rail = home.rail;          // CMS-managed: src/data/home.json → rail (title, subtitle, cards[])
const cards = rail.cards;
const N = cards.length;
// clone last at front + first at back so a peek always shows on BOTH ends and it loops
const rendered = [
  { ...cards[N - 1], _clone: true },
  ...cards.map((c) => ({ ...c, _clone: false })),
  { ...cards[0], _clone: true },
];

// simple apparel glyphs per category (currentColor → inherits the icon-circle's white)
const ICONS: Record<string, string> = {
  'T-Shirt':     '<path fill="currentColor" d="M8.4 3 3.5 6.1l2 3.5 1.8-1V21h9.4V8.6l1.8 1 2-3.5L15.6 3a3.6 3.6 0 0 1-7.2 0Z"/>',
  'Jersey':      '<path fill="currentColor" d="M8.4 3 3.5 6.1l2 3.5 1.8-1V21h9.4V8.6l1.8 1 2-3.5L15.6 3 12 6.6 8.4 3Z"/>',
  'Workshirt':   '<path fill="currentColor" d="M8.6 3 4 6.2l1.8 3.2 1.4-.8V21h9.6V8.6l1.4.8L20 6.2 15.4 3 12 6.1 8.6 3Z"/>',
  'Jacket':      '<path fill="currentColor" d="M8.6 3 4 6.2l2 3.4 1-.7V21h4.2V3H8.6Zm6.8 0H12.8v18H17V8.9l1 .7 2-3.4L15.4 3Z"/>',
  'Rompi':       '<path fill="currentColor" d="M8.4 3 12 7.2 15.6 3l2 1.7-2 3.3 1.4-.6V21H7V7.4l1.4.6-2-3.3L8.4 3Z"/>',
  'Jas':         '<path fill="currentColor" d="M9 3 6.4 6.4 6 21h4.6l1-7.5 1 7.5H17l-.4-14.6L14 3l-2.5 3.4L9 3Z"/>',
  'Merchandise': '<path fill="currentColor" fill-rule="evenodd" d="M9 7V6a3 3 0 0 1 6 0v1h2.6l.9 14H5.5l.9-14H9Zm1.5 0h3V6a1.5 1.5 0 0 0-3 0v1Z"/>',
};
const iconFor = (name: string) => ICONS[name] || ICONS['T-Shirt'];
const STAR = '<path fill="currentColor" d="M12 2.6l2.85 5.78 6.38.93-4.62 4.5 1.09 6.35L12 17.56l-5.7 3 1.09-6.35-4.62-4.5 6.38-.93z"/>';
---
<section class="lg-rail" aria-labelledby="lg-rail-title">
  <!-- blurred backdrop (mobile only) — two layers crossfade to the centered card -->
  <div class="lg-rail-bg" aria-hidden="true">
    <div class="lg-rail-bg-layer" data-bg-a></div>
    <div class="lg-rail-bg-layer" data-bg-b></div>
    <div class="lg-rail-veil"></div>
  </div>

  <div class="lg-rail-head">
    <h2 id="lg-rail-title" class="lg-rail-title">{rail.title}</h2>
    {(rail as any).subtitle && <p class="lg-rail-sub">{(rail as any).subtitle}</p>}
  </div>

  <div class="lg-rail-track" data-track>
    {rendered.map((c) => (
      <a class="lg-rail-item" href={c.href} data-img={c.image}
         data-clone={c._clone ? 'true' : 'false'}
         aria-hidden={c._clone ? 'true' : undefined} tabindex={c._clone ? -1 : undefined}>
        <div class="lg-rail-img"><img class="lg-rv" src={c.image} alt={c.name} loading="lazy" /></div>
        <div class="lg-rail-meta">
          <span class="lg-rail-ico" set:html={`<svg viewBox="0 0 24 24" width="100%" height="100%">${iconFor(c.name)}</svg>`}></span>
          <span class="lg-rail-label">{c.name}</span>
          {(c as any).featured && (
            <span class="lg-rail-badge" aria-label="Unggulan" set:html={`<svg viewBox="0 0 24 24" width="100%" height="100%">${STAR}</svg>`}></span>
          )}
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  :root { --lg-primary: #AF7AD5; --lg-primary-dark: #9A66C2; --lg-ink: #1A1A2E; }

  .lg-rail { padding: 5.6svh 0 clamp(2.5rem, 6vw, 4.5rem); background: transparent; }

  /* blurred backdrop, star/icon, and the loop clones are mobile-only — off by default */
  .lg-rail-bg { display: none; }
  .lg-rail-ico, .lg-rail-badge { display: none; }
  .lg-rail-item[data-clone="true"] { display: none; }   /* desktop: no clones, plain editorial rail */

  /* heading aligns to the first card's left edge */
  .lg-rail-head { padding: 0 clamp(1.25rem, 4vw, 3rem); margin: 0 0 clamp(1.25rem, 3vw, 2rem); }
  .lg-rail-title { font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(1.4rem,2.6vw,2.1rem); line-height:1.05; letter-spacing:-.02em; color:var(--lg-ink); margin:0; }
  .lg-rail-sub { display: none; }   /* subhead shown on mobile only */

  /* flush, free-scroll rail — next card peeks on the right */
  .lg-rail-track {
    display: flex; gap: 0;
    overflow-x: auto; scroll-snap-type: x proximity; scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch; scrollbar-width: none;
    padding: 0 clamp(1.25rem, 4vw, 3rem) 0 0;
    scroll-padding-left: 0;
  }
  .lg-rail-track::-webkit-scrollbar { display: none; }

  .lg-rail-item { flex: 0 0 clamp(15rem, 31vw, 26rem); scroll-snap-align: start; text-decoration: none; display: block; }
  .lg-rail-img { aspect-ratio: 5 / 7; overflow: hidden; background: #f1ecf6; }   /* tall vertical, sharp corners */
  .lg-rail-img img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* small caption, left-aligned under the media */
  .lg-rail-label {
    display: block; margin-top: clamp(.55rem, 1.1vw, .8rem); padding: 0 1rem 0 1.5rem;
    font-family:'Inter',sans-serif; font-weight:600; font-size:.85rem; line-height:1.3;
    color:var(--lg-ink); transition: color .25s ease;
  }
  @media (hover: hover) { .lg-rail-item:hover .lg-rail-label { color: var(--lg-primary-dark); } }

  /* ============ MOBILE reels panel (≤767px): full-screen "IG Edits" looping carousel ============ */
  @media (max-width: 767px) {
    .lg-rail { padding: 0; position: relative; display: flex; flex-direction: column;
      background: #19122b; overflow: hidden; }

    /* blurred, purple-tinted backdrop */
    .lg-rail-bg { display: block; position: absolute; inset: 0; z-index: 0; }
    .lg-rail-bg-layer { position: absolute; inset: -10%; background-size: cover; background-position: center;
      filter: blur(34px) brightness(.62) saturate(1.1); transform: scale(1.12); opacity: 0; transition: opacity .55s ease; }
    .lg-rail-veil { position: absolute; inset: 0;
      background: linear-gradient(155deg, rgba(175,122,213,.34) 0%, rgba(40,24,66,.5) 55%, rgba(20,13,34,.66) 100%); }

    /* head: bold title + lighter subhead, centered up top */
    .lg-rail-head { position: relative; z-index: 2; flex: 0 0 auto; text-align: center; margin: 0;
      padding: calc(env(safe-area-inset-top, 0px) + 2.7rem) 1.5rem 0; pointer-events: none; }
    .lg-rail-title { color: #fff; font-size: clamp(1.55rem, 6.4vw, 2.05rem); font-weight: 800;
      text-shadow: 0 2px 20px rgba(0,0,0,.4); }
    .lg-rail-sub { display: block; margin: .55rem auto 0; max-width: 22rem; color: rgba(255,255,255,.82);
      font-family:'Inter',sans-serif; font-weight: 400; font-size: .95rem; line-height: 1.45;
      text-shadow: 0 1px 10px rgba(0,0,0,.35); }

    /* carousel fills the rest, cards centered with peek; clones visible for the loop */
    .lg-rail-item[data-clone="true"] { display: block; }
    .lg-rail-track { position: relative; z-index: 1; flex: 1 1 auto; align-items: center;
      gap: clamp(.5rem, 2.5vw, 1rem); padding: 0 0 calc(4.6rem + env(safe-area-inset-bottom, 0px));
      scroll-snap-type: x mandatory; scroll-padding: 0; scroll-behavior: auto; }   /* belt-and-suspenders: never smooth on mobile (loop jump must be instant) */

    .lg-rail-item { position: relative; flex: 0 0 auto; display: block;
      height: clamp(19rem, 53vh, 31rem); aspect-ratio: 9 / 14;
      border-radius: clamp(1rem, 4.5vw, 1.5rem); overflow: hidden;
      scroll-snap-align: center;
      transform: scale(.87); opacity: .5; transition: transform .4s cubic-bezier(.19,1,.22,1), opacity .4s ease; }
    .lg-rail-item.is-center { transform: scale(1); opacity: 1; }
    /* legibility scrim for the meta row */
    .lg-rail-item::after { content: ''; position: absolute; inset: 0; border-radius: inherit; z-index: 1; pointer-events: none;
      background: linear-gradient(to top, rgba(0,0,0,.58) 0%, rgba(0,0,0,.12) 28%, transparent 46%); }

    .lg-rail-img { position: static; width: 100%; height: 100%; aspect-ratio: auto; border-radius: inherit; }

    /* in-card account-style row: icon circle · name · star badge */
    .lg-rail-meta { position: absolute; left: .75rem; right: .65rem; bottom: .8rem; z-index: 2;
      display: flex; align-items: center; gap: .5rem; }
    .lg-rail-ico { display: grid; place-items: center; flex: 0 0 auto; width: 1.75rem; height: 1.75rem;
      padding: .34rem; border-radius: 999px; color: #fff;
      background: rgba(255,255,255,.22); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,.32); }
    .lg-rail-label { display: block; margin: 0; padding: 0; color: #fff; font-weight: 600;
      font-size: .98rem; letter-spacing: 0; text-shadow: 0 1px 8px rgba(0,0,0,.55); }
    .lg-rail-badge { display: grid; place-items: center; flex: 0 0 auto; width: 1.05rem; height: 1.05rem;
      color: #FFC107; filter: drop-shadow(0 1px 4px rgba(0,0,0,.45)); }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.lg-rail').forEach((root) => {
    const track = root.querySelector<HTMLElement>('[data-track]');
    const items = Array.from(root.querySelectorAll<HTMLElement>('.lg-rail-item'));
    let bgCur = root.querySelector<HTMLElement>('[data-bg-a]');
    let bgNext = root.querySelector<HTMLElement>('[data-bg-b]');
    if (!track || items.length < 3) return;
    // only drive the looping/blur behaviour on the mobile panel
    if (!window.matchMedia('(max-width: 767px)').matches) return;

    const N = items.length - 2;       // real card count (excludes 2 clones)
    const LAST = items.length - 1;    // trailing clone index

    // cache each card's center once (cards are fixed-size) — avoids per-frame layout reads = smoother scroll
    let centers: number[] = [];
    const measure = () => { centers = items.map((it) => it.offsetLeft + it.offsetWidth / 2); };
    const setScroll = (r: number, smooth: boolean) =>
      // 'instant' (not 'auto') — 'auto' falls back to CSS scroll-behavior:smooth and would
      // animate the wrap-jump across the whole track. The loop jump must be invisible.
      track.scrollTo({ left: centers[r] - track.clientWidth / 2, behavior: smooth ? 'smooth' : 'instant' });

    let curR = 1;        // current rendered index (start on first real card)
    let lastImg = '';
    const setBg = (img?: string) => {
      if (!img || img === lastImg || !bgCur || !bgNext) return;
      lastImg = img;
      bgNext.style.backgroundImage = `url("${img}")`;
      bgNext.style.opacity = '1';
      bgCur.style.opacity = '0';
      [bgCur, bgNext] = [bgNext, bgCur];
    };

    const paint = () => {
      const c = track.scrollLeft + track.clientWidth / 2;
      let best = 1, bestD = Infinity;
      for (let i = 0; i < centers.length; i++) { const d = Math.abs(centers[i] - c); if (d < bestD) { bestD = d; best = i; } }
      curR = best;
      items.forEach((it, i) => it.classList.toggle('is-center', i === best));
      setBg(items[best].dataset.img);
    };

    // when settled on a clone, jump instantly to the matching real card (seamless wrap)
    const settleLoop = () => {
      if (curR === 0) { curR = N; setScroll(N, false); }
      else if (curR === LAST) { curR = 1; setScroll(1, false); }
    };

    let raf = 0, stop = 0;
    track.addEventListener('scroll', () => { cancelAnimationFrame(raf); raf = requestAnimationFrame(paint); }, { passive: true });
    // settle the loop the INSTANT scrolling stops (no artificial delay). scrollend where supported, else a short timeout.
    if ('onscrollend' in window) {
      track.addEventListener('scrollend', settleLoop, { passive: true });
    } else {
      track.addEventListener('scroll', () => { clearTimeout(stop); stop = window.setTimeout(settleLoop, 80); }, { passive: true });
    }

    // start centered on the first real card (left peek = clone of last)
    requestAnimationFrame(() => { measure(); setScroll(1, false); paint(); });
    window.addEventListener('resize', () => { measure(); setScroll(curR, false); });
  });
</script>
