---
/**
 * Level Garment hero — full-screen (100svh) IG-story banner. Each slide carries
 * its OWN title + description (fades as slides advance). Title is the CTA
 * (underline-draws on hover, clickable). Story indicator = dots + active fill-pill,
 * centered at the bottom.
 */
interface Props { variant?: 'default' | 'simple'; }
const { variant = 'default' } = Astro.props;

import home from '../../data/home.json';
// 5 slides — first is a video, the rest images (CMS-managed via src/data/home.json → hero.slides).
const slides = home.hero.slides;
---
<section id="hero" class="lg-hero" data-slides={slides.length}>
  <div class="lg-hero-slides">
    {slides.map((s, i) => (
      <div class:list={['lg-hero-slide', { 'is-active': i === 0, 'is-init': i === 0 }]} data-i={i}
           data-title={s.title} data-desc={s.desc} data-href={s.href}>
        {s.video
          ? <video src={s.video} autoplay loop muted playsinline preload="metadata"></video>
          : <picture>
              {(s as any).imageMobile && <source srcset={(s as any).imageMobile} media="(max-width: 1023px)" />}
              <img src={s.image} alt="" loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : undefined} />
            </picture>}
      </div>
    ))}
    <div class="lg-hero-scrim" aria-hidden="true"></div>
  </div>

  <button class="lg-hero-nav lg-hero-nav-prev" aria-label="Slide sebelumnya" data-prev>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
  </button>
  <button class="lg-hero-nav lg-hero-nav-next" aria-label="Slide berikutnya" data-next>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
  </button>

  <div class="lg-hero-bottom">
    <div class="lg-hero-copy" data-copy>
      <h1 class="lg-hero-title"><a id="lg-hero-link" href={slides[0].href}>{slides[0].title}</a></h1>
      <p class="lg-hero-sub" id="lg-hero-sub">{slides[0].desc}</p>
    </div>
  </div>

  <div class="lg-hero-progress" aria-hidden="true">
    {slides.map((_, i) => (<span class="lg-hp" data-i={i}><i></i></span>))}
  </div>
</section>

<style>
  :root { --lg-primary: #AF7AD5; --lg-amber: #FFC107; --lg-ink: #1A1A2E; }
  /* FIXED aspect-ratio (KG approach) so the crop is consistent across devices, not viewport-dependent */
  .lg-hero { position: relative; width: 100%; aspect-ratio: 16 / 9; min-height: 30rem; overflow: hidden; background: #1A1A2E; isolation: isolate; }
  @media (max-width: 1023px) { .lg-hero { aspect-ratio: 4 / 5; } }

  .lg-hero-slides { position: absolute; inset: 0; z-index: 0; }
  .lg-hero-slide { position: absolute; inset: 0; opacity: 0; z-index: 0; will-change: transform, filter; }
  /* TikTok whip-pan — direction-aware: forward (next) swipes right, backward (prev) swipes left */
  .lg-hero-slide.is-active  { opacity: 1; z-index: 1; animation: lg-whip-in-l  .58s cubic-bezier(.5,0,.18,1) both; }
  .lg-hero-slide.is-leaving { opacity: 1; z-index: 2; animation: lg-whip-out-l .58s cubic-bezier(.5,0,.18,1) both; }
  .lg-hero-slide.is-active.is-back  { animation-name: lg-whip-in-r; }
  .lg-hero-slide.is-leaving.is-back { animation-name: lg-whip-out-r; }
  .lg-hero-slide.is-init { animation: none; }   /* first slide on load — no whip intro */
  @keyframes lg-whip-in-r  { from { transform: translate3d(-100%,0,0); filter: blur(6px); } to { transform: translate3d(0,0,0); filter: blur(0); } }
  @keyframes lg-whip-out-r { from { transform: translate3d(0,0,0); filter: blur(0); } to { transform: translate3d(100%,0,0); filter: blur(6px); } }
  @keyframes lg-whip-in-l  { from { transform: translate3d(100%,0,0); filter: blur(6px); } to { transform: translate3d(0,0,0); filter: blur(0); } }
  @keyframes lg-whip-out-l { from { transform: translate3d(0,0,0); filter: blur(0); } to { transform: translate3d(-100%,0,0); filter: blur(6px); } }
  .lg-hero-slide img, .lg-hero-slide video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lg-hero-scrim { position: absolute; inset: 0; background:
    linear-gradient(to top, rgba(18,18,30,.92) 0%, rgba(18,18,30,.66) 22%, rgba(18,18,30,.30) 46%, rgba(18,18,30,0) 72%); }
  /* hidden for now (kept in markup) — no overlay, no text. (dots = .lg-hero-progress shown) */
  .lg-hero-scrim, .lg-hero-bottom { display: none; }

  .lg-hero-bottom { position: absolute; z-index: 3; bottom: clamp(2.4rem, 7vh, 4rem); left: clamp(1.5rem, 5vw, 4rem); right: clamp(1.5rem, 5vw, 4rem); color: #fff; }
  .lg-hero-copy { max-width: 38rem; transition: opacity .4s ease, transform .4s ease; }
  .lg-hero-copy.is-swapping { opacity: 0; transform: translateY(10px); }
  .lg-hero-title { color: #fff; font-family:'Inter',sans-serif; font-weight:800; font-size: clamp(2.4rem, 6.5vw, 5rem); line-height: 1; letter-spacing:-.03em; margin: 0 0 .85rem; text-shadow: 0 2px 24px rgba(0,0,0,.55), 0 1px 3px rgba(0,0,0,.4); white-space: nowrap; }
  .lg-hero-title a { color: inherit; text-decoration: none; position: relative; display: inline-block; }
  .lg-hero-title a::after { content: ''; position: absolute; left: 0; right: 0; bottom: 0.04em; height: 0.055em; background: currentColor; transform: scaleX(0); transform-origin: left center; transition: transform .45s cubic-bezier(.19,1,.22,1); }
  @media (hover: hover) { .lg-hero-title a:hover::after { transform: scaleX(1); } }
  .lg-hero-sub { font-family:'Inter',sans-serif; font-weight:500; font-size: clamp(.98rem,1.4vw,1.15rem); line-height:1.5; color: rgba(255,255,255,.92); margin: 0;
    display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; max-width: 32rem; }

  /* hover-reveal prev/next (show only when hovering the left/right edge) */
  .lg-hero-nav { position: absolute; top: 0; bottom: 0; width: 16%; min-width: 4rem; z-index: 1; display: grid; place-items: center; background: none; border: 0; cursor: pointer; opacity: 0; transition: opacity .3s ease; }
  .lg-hero-nav-prev { left: 0; } .lg-hero-nav-next { right: 0; }
  .lg-hero-nav svg { width: 2rem; height: 2rem; color: #fff; filter: drop-shadow(0 2px 10px rgba(0,0,0,.5)); transition: transform .2s ease; }
  @media (hover: hover) { .lg-hero-nav:hover { opacity: 1; } .lg-hero-nav-prev:hover svg { transform: translateX(-3px); } .lg-hero-nav-next:hover svg { transform: translateX(3px); } }

  .lg-hero-progress { position: absolute; z-index: 3; left: 50%; transform: translateX(-50%); bottom: clamp(1.4rem, 4vh, 2.4rem); display: flex; align-items: center; gap: .5rem; }
  .lg-hp { position: relative; width: 7px; height: 7px; border-radius: 999px; background: rgba(255,255,255,.5); overflow: hidden; transition: width .45s cubic-bezier(.19,1,.22,1), background .3s ease; flex: 0 0 auto; }
  .lg-hp i { position:absolute; inset:0; width:0; background:#fff; border-radius:999px; }
  .lg-hp.is-done { background: rgba(255,255,255,.5); }
  .lg-hp.is-active { width: 2.4rem; background: rgba(255,255,255,.35); }
  .lg-hp.is-active i { width: 100%; transition: width var(--dur, 4.2s) linear; }

  @media (prefers-reduced-motion: reduce){ .lg-hero-slide.is-active{ animation:none; } .lg-hero-slide.is-leaving{ animation:none; opacity:0; } .lg-hp.is-active i{ transition:none; width:100%; } }

  /* MOBILE reels: Instagram-Stories progress — pinned to the TOP. Segments fill left→right
     and STAY filled: done = solid white, active = dim track filling, ahead = dim. */
  @media (max-width: 767px) {
    .lg-hero-progress { top: calc(.6rem + env(safe-area-inset-top, 0px)); bottom: auto; left: 0; right: 0; transform: none; padding: 0 .7rem; gap: 4px; }
    .lg-hp { flex: 1 1 0; width: auto; height: 3px; border-radius: 999px; background: rgba(255,255,255,.4); }
    .lg-hp.is-active { width: auto; background: rgba(255,255,255,.4); }   /* dim track; <i> fills white over the slide's duration */
    .lg-hp.is-done { width: auto; background: #fff; }                     /* completed → solid white, stays filled */
    .lg-hp i { background: #fff; }
  }
</style>

<script>
  const hero = document.getElementById('hero');
  if (hero) {
    const slides = Array.from(hero.querySelectorAll<HTMLElement>('.lg-hero-slide'));
    const bars = Array.from(hero.querySelectorAll<HTMLElement>('.lg-hp'));
    const copy = hero.querySelector<HTMLElement>('[data-copy]');
    const link = document.getElementById('lg-hero-link') as HTMLAnchorElement | null;
    const sub = document.getElementById('lg-hero-sub');
    const DUR = 4200;
    let cur = 0; let timer: ReturnType<typeof setTimeout> | null = null;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const swapCopy = (el: HTMLElement) => {
      const t = el.dataset.title || '', d = el.dataset.desc || '', h = el.dataset.href || '#';
      if (!copy) return;
      copy.classList.add('is-swapping');
      setTimeout(() => {
        if (link) { link.textContent = t; link.setAttribute('href', h); link.target = h.startsWith('http') ? '_blank' : ''; }
        if (sub) sub.textContent = d;
        copy.classList.remove('is-swapping');
      }, 280);
    };

    const show = (n: number, dir: number = 1) => {
      const prev = cur;
      slides.forEach((s) => s.classList.remove('is-leaving', 'is-back', 'is-init'));
      slides[prev].classList.remove('is-active');
      slides[prev].classList.add('is-leaving');
      if (dir < 0) slides[prev].classList.add('is-back');
      cur = (n + slides.length) % slides.length;
      // Stories progress, declarative by position (works forward AND backward):
      // segments before cur = full, cur = filling (set by activateBar), ahead = empty.
      bars.forEach((b, i) => { b.classList.remove('is-active'); b.classList.toggle('is-done', i < cur); });
      slides[cur].classList.add('is-active');
      if (dir < 0) slides[cur].classList.add('is-back');
      swapCopy(slides[cur]);
      scheduleNext();
    };

    // Light up the current dot and run its fill over `durMs` (matches the slide's real dwell time).
    const activateBar = (durMs: number) => {
      bars[cur].style.setProperty('--dur', durMs + 'ms');
      void bars[cur].offsetWidth;        // restart the fill transition
      bars[cur].classList.add('is-active');
    };

    // Image slides dwell for DUR; the video slide dwells for its FULL duration —
    // and the loading dot's fill follows whichever it is.
    function scheduleNext() {
      if (timer) { clearTimeout(timer); timer = null; }
      const vid = slides[cur].querySelector('video') as HTMLVideoElement | null;
      if (vid) {
        const go = () => {
          try { vid.currentTime = 0; vid.play().catch(() => {}); } catch {}
          const dur = (isFinite(vid.duration) && vid.duration > 0) ? vid.duration : 8;
          activateBar(dur * 1000);
          if (!reduce) timer = setTimeout(() => show(cur + 1), dur * 1000);
        };
        if (isFinite(vid.duration) && vid.duration > 0) go();
        else vid.addEventListener('loadedmetadata', go, { once: true });
        return;
      }
      activateBar(DUR);
      if (!reduce) timer = setTimeout(() => show(cur + 1), DUR);
    }
    // kick off slide 0 — fills its dot over the video's real duration, then advances
    scheduleNext();

    // hover-reveal prev/next
    hero.querySelector('[data-prev]')?.addEventListener('click', () => show(cur - 1, -1));
    hero.querySelector('[data-next]')?.addEventListener('click', () => show(cur + 1, 1));
  }
</script>
