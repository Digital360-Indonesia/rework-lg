---
/**
 * Section 3 — video banner.
 *  • Desktop: full-width video, centered copy at the bottom. No CTA button — the
 *    heading itself is the link (underline draws in on hover, clickable).
 *  • Mobile (≤767px): full-screen panel (height from index.astro), bold head +
 *    lighter subhead in the lower third over the video. Loop-edited clip → plain
 *    <video loop> is seamless.
 * CMS-managed via src/data/home.json → videoBanner (videoDesktop, videoMobile,
 * title, subtitle, href). When videoMobile is blank the desktop clip fits all sizes.
 */
import home from '../../data/home.json';
import lqip from '../../data/video-lqip.json';
const { videoDesktop, videoMobile, title, subtitle, href } = home.videoBanner as any;
const link = href || '/product/';
// instant blur-up first-frames (ds + mb) so the banner never flashes its dark background pre-play
const L = (v?: string) => { if (!v) return ''; const k = (lqip as Record<string,string>)[v.split('/').pop()!.replace(/\.\w+$/, '')]; return k ? `url(${k})` : ''; };
const lqipVars = `--lqip-ds:${L(videoDesktop)};--lqip-mb:${L(videoMobile || videoDesktop)}`;
---
<section id="banner" class="lg-banner" aria-label="Banner" style={lqipVars}>
  <!-- no <source media> (unreliable on <video>) — JS picks ds/mb via matchMedia below -->
  <video class="lg-banner-video lg-rv" loop muted playsinline preload="none"
         data-ds={videoDesktop} data-mb={videoMobile || videoDesktop}></video>
  <div class="lg-banner-scrim" aria-hidden="true"></div>

  <div class="lg-banner-copy">
    <h2 class="lg-banner-title"><a class="lg-banner-link" href={link}>{title}</a></h2>
    <p class="lg-banner-sub">{subtitle}</p>
  </div>
</section>

<style>
  .lg-banner {
    position: relative; width: 100%;
    height: clamp(32rem, 92vh, 56rem);
    margin: clamp(1.75rem, 4vw, 3.25rem) 0;   /* the "break" above & below (desktop only) */
    overflow: hidden; background-color: #1A1A2E; isolation: isolate;
    background-image: var(--lqip-ds); background-size: cover; background-position: center;   /* blur-up first-frame under the video */
  }
  @media (max-width: 767px) { .lg-banner { background-image: var(--lqip-mb); } }
  .lg-banner-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; display: block; }
  .lg-banner-scrim { position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(to top, rgba(0,0,0,.5) 0%, rgba(0,0,0,.18) 26%, rgba(0,0,0,0) 52%); }

  .lg-banner-copy { position: absolute; inset: 0; z-index: 2; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; text-align: center; padding: 2rem 2rem clamp(2.5rem, 6vh, 4.5rem); color: #fff; }
  .lg-banner-title { color:#fff; font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(2.2rem,5vw,4rem); line-height:1.04; letter-spacing:-.03em; margin:0 0 1rem; text-shadow:0 2px 26px rgba(0,0,0,.45); }
  /* heading = the CTA: underline draws IN on hover (hero pattern), clickable */
  .lg-banner-link { color: inherit; text-decoration: none; position: relative; display: inline-block; }
  .lg-banner-link::after { content:''; position:absolute; left:0; right:0; bottom:.02em; height:.05em; background:currentColor;
    transform: scaleX(0); transform-origin: left center; transition: transform .45s cubic-bezier(.19,1,.22,1); }
  @media (hover:hover){ .lg-banner-link:hover::after { transform: scaleX(1); } }
  .lg-banner-sub { font-family:'Inter',sans-serif; font-weight:500; font-size:clamp(1rem,1.4vw,1.2rem); line-height:1.55; max-width:38rem; margin:0; color:rgba(255,255,255,.94); text-shadow:0 1px 14px rgba(0,0,0,.4); }

  /* ============ MOBILE reels panel (≤767px): full-screen video, copy in the lower third ============ */
  @media (max-width: 767px) {
    /* height + margin:0 come from index.astro panel rule */
    .lg-banner-scrim { background: linear-gradient(to top, rgba(0,0,0,.66) 0%, rgba(0,0,0,.28) 30%, rgba(0,0,0,0) 60%); }
    .lg-banner-copy { padding: 2rem 1.4rem calc(5.8rem + env(safe-area-inset-bottom, 0px)); }
    .lg-banner-title { font-size: clamp(1.95rem, 8.5vw, 2.7rem); margin: 0 0 .7rem; }
    .lg-banner-sub { font-weight: 400; font-size: 1rem; max-width: 23rem; color: rgba(255,255,255,.9); }
  }
</style>

<script>
  const v = document.querySelector<HTMLVideoElement>('.lg-banner-video');
  if (v) {
    // pick mobile vs desktop source ourselves (reliable, unlike <source media> on video)
    const mq = window.matchMedia('(max-width: 1023px)');
    const pick = () => (mq.matches ? v.dataset.mb : v.dataset.ds) || v.dataset.ds || '';
    // Don't download until the banner is actually on screen — on the mobile reels feed every section
    // sits in the DOM at once, so eager-loading here starved the hero. IO sets src + plays on entry,
    // pauses on exit. (preload="none" + no initial src ⇒ zero bytes until visible.)
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const want = pick();
          if (want && v.getAttribute('src') !== want) { v.src = want; v.load(); }
          v.play().catch(() => {});
        } else { v.pause(); }
      });
    }, { threshold: 0.25 });
    io.observe(v);
    mq.addEventListener('change', () => {   // re-pick on rotate/resize across the breakpoint
      const want = pick();
      if (v.getAttribute('src') && want && v.getAttribute('src') !== want) { v.src = want; v.load(); v.play().catch(() => {}); }
    });
  }
</script>
