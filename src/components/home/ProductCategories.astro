---
/**
 * Product categories — horizontal "Shop by Category" carousel (RL model).
 * One-line heading, clear background, larger cards with the next peeking; scroll
 * via arrows or swipe; a progress line tracks position. Built for 6 categories.
 */
import products from '../../data/products.json';
const real = (products.categories || []);
const ph = (n: number) => `/assets/images/placeholder/${['image.png','image copy.png','image copy 2.png','image copy 3.png','image copy 4.png','image copy 5.png'][n].replace(/ /g, '%20')}`;

// 6 cards = 4 real categories + 2 stand-ins (rename later)
const cards = [
  ...real.slice(0, 4).map((c: any, i: number) => ({ name: c.name, href: `/product/${c.anchor || ''}`, img: ph(i) })),
  { name: 'Hoodie', href: '/product/', img: ph(4) },
  { name: 'Topi',   href: '/product/', img: ph(5) },
];
---
<section class="lg-cats" aria-labelledby="lg-cats-title">
  <div class="lg-cats-inner">
    <h2 id="lg-cats-title" class="lg-cats-title">Pilih Kategori</h2>
  </div>

  <div class="lg-cats-carousel">
    <button class="lg-cats-arrow lg-cats-prev" aria-label="Geser kiri" data-prev>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
    </button>

    <div class="lg-cats-track" data-track>
      {cards.map((c) => (
        <a class="lg-cat" href={c.href}>
          <div class="lg-cat-img">
            <img src={c.img} alt={c.name} loading="lazy" />
          </div>
          <span class="lg-cat-label">{c.name}</span>
        </a>
      ))}
    </div>

    <button class="lg-cats-arrow lg-cats-next" aria-label="Geser kanan" data-next>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>

  <div class="lg-cats-inner">
    <div class="lg-cats-progress" aria-hidden="true"><span class="lg-cats-thumb" data-thumb></span></div>
  </div>
</section>

<style>
  :root { --lg-primary: #AF7AD5; --lg-primary-dark: #9A66C2; --lg-ink: #1A1A2E; }

  .lg-cats { padding: 5.6svh 0 clamp(2.5rem, 6vw, 4.5rem); background: transparent; }

  .lg-cats-inner { max-width: 96rem; margin: 0 auto; padding: 0 clamp(1.5rem, 4vw, 3rem); }
  .lg-cats-title { font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(2rem,4vw,3.1rem); line-height:1.05; letter-spacing:-.03em; color:var(--lg-ink); margin:0 0 clamp(1.5rem,3.5vw,2.5rem); white-space: nowrap; }

  /* carousel */
  .lg-cats-carousel { position: relative; max-width: 96rem; margin: 0 auto; }
  .lg-cats-track {
    display: flex; gap: clamp(.9rem, 1.6vw, 1.4rem);
    overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch; scrollbar-width: none;
    padding: 0 clamp(1.5rem, 4vw, 3rem); scroll-padding-left: clamp(1.5rem, 4vw, 3rem);
  }
  .lg-cats-track::-webkit-scrollbar { display: none; }
  .lg-cat { flex: 0 0 clamp(15rem, 29vw, 22rem); scroll-snap-align: start; text-decoration: none; display: block; }
  .lg-cat-img {
    aspect-ratio: 4 / 5; border-radius: .25rem; overflow: hidden; background: #f1ecf6;
  }
  .lg-cat-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lg-cat-label { display: block; margin-top: .95rem; font-family:'Inter',sans-serif; font-weight:700; font-size:.92rem; letter-spacing:.08em; text-transform:uppercase; color:var(--lg-ink); transition: color .25s ease; }
  @media (hover: hover) {
    .lg-cat:hover .lg-cat-label { color: var(--lg-primary-dark); }
  }

  /* arrows */
  .lg-cats-arrow {
    position: absolute; top: 40%; transform: translateY(-50%); z-index: 4;
    width: 2.9rem; height: 2.9rem; border-radius: 999px;
    background: rgba(255,255,255,.9); backdrop-filter: blur(6px);
    border: 1px solid rgba(26,26,46,.08); color: var(--lg-ink);
    display: grid; place-items: center; cursor: pointer;
    box-shadow: 0 8px 24px -10px rgba(26,26,46,.3);
    transition: background .2s ease, transform .2s ease, opacity .2s ease;
  }
  .lg-cats-arrow svg { width: 1.3rem; height: 1.3rem; }
  .lg-cats-prev { left: clamp(.5rem, 2vw, 1.5rem); }
  .lg-cats-next { right: clamp(.5rem, 2vw, 1.5rem); }
  @media (hover: hover) { .lg-cats-arrow:hover { background: #fff; transform: translateY(-50%) scale(1.06); } }
  .lg-cats-arrow[disabled] { opacity: 0; pointer-events: none; }

  /* progress line */
  .lg-cats-progress { margin-top: clamp(1.5rem, 3vw, 2.25rem); height: 2px; background: rgba(175,122,213,.18); border-radius: 999px; position: relative; overflow: hidden; }
  .lg-cats-thumb { position: absolute; left: 0; top: 0; height: 100%; width: 30%; background: var(--lg-primary); border-radius: 999px; transition: transform .15s ease; }

  @media (max-width: 720px) {
    .lg-cat { flex-basis: 70vw; }
    .lg-cats-arrow { display: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.lg-cats-carousel').forEach((wrap) => {
    const track = wrap.querySelector<HTMLElement>('[data-track]');
    const prev = wrap.querySelector<HTMLButtonElement>('[data-prev]');
    const next = wrap.querySelector<HTMLButtonElement>('[data-next]');
    const thumb = wrap.closest('.lg-cats')?.querySelector<HTMLElement>('[data-thumb]');
    if (!track) return;

    const update = () => {
      const max = track.scrollWidth - track.clientWidth;
      const ratio = max > 0 ? track.scrollLeft / max : 0;
      if (thumb) {
        const vis = Math.min(1, track.clientWidth / track.scrollWidth);
        thumb.style.width = (vis * 100) + '%';
        thumb.style.transform = `translateX(${ratio * (100 / vis - 100)}%)`;
      }
      if (prev) prev.disabled = track.scrollLeft <= 2;
      if (next) next.disabled = track.scrollLeft >= max - 2;
    };

    const page = () => Math.max(track.clientWidth * 0.8, 240);
    prev?.addEventListener('click', () => track.scrollBy({ left: -page(), behavior: 'smooth' }));
    next?.addEventListener('click', () => track.scrollBy({ left: page(), behavior: 'smooth' }));
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  });
</script>
