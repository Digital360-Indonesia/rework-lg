---
/**
 * End CTA — Vans "Join the list" model, re-skinned to a soft purple checkerboard.
 * Simple 2-field form (WhatsApp number + kebutuhan) that opens WhatsApp prefilled
 * on submit, plus an "atau langsung WhatsApp" link with the WA icon below.
 */
const waNumber = '6285183091599';
const waDirect = `https://wa.me/${waNumber}?text=` + encodeURIComponent('Halo Level Garment, aku mau konsultasi & pesan custom buat acara/kelas.');
---
<section class="lg-cta" aria-labelledby="lg-cta-title">
  <div class="lg-cta-checker" aria-hidden="true"></div>
  <div class="lg-cta-inner">
    <h2 id="lg-cta-title" class="lg-cta-title">Mulai Pesananmu</h2>
    <p class="lg-cta-sub">Isi sebentar, langsung terhubung ke tim kami di WhatsApp.</p>

    <form class="lg-cta-form" data-waform data-wa={waNumber}>
      <input type="tel" name="phone" inputmode="tel" placeholder="Nomor WhatsApp" aria-label="Nomor WhatsApp" required />
      <span class="lg-cta-div" aria-hidden="true"></span>
      <input type="text" name="need" placeholder="Kebutuhanmu (cth: jaket angkatan 40 pcs)" aria-label="Kebutuhan" />
      <button type="submit" aria-label="Kirim ke WhatsApp">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </button>
    </form>

    <p class="lg-cta-consent">Dengan mengirim, kamu akan diarahkan ke WhatsApp tim Level Garment.</p>

    <a class="lg-cta-wa" href={waDirect} target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.06 24l1.69-6.16a11.86 11.86 0 0 1-1.59-5.95C.16 5.34 5.5 0 12.06 0a11.82 11.82 0 0 1 8.41 3.49 11.82 11.82 0 0 1 3.48 8.42c0 6.55-5.34 11.89-11.9 11.89a11.9 11.9 0 0 1-5.68-1.45L.06 24Zm6.6-3.8c1.68.99 3.28 1.59 5.4 1.59 5.45 0 9.89-4.43 9.89-9.88a9.86 9.86 0 0 0-9.88-9.89C6.6 2.02 2.16 6.45 2.16 11.9c0 2.23.65 3.9 1.74 5.65l-1 3.65 3.76-.99ZM17.42 14.5c-.07-.12-.27-.2-.56-.34-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.64.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.76-1.64-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.21-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.22 3.08.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.42.25-.69.25-1.29.18-1.41Z"/></svg>
      atau langsung WhatsApp
    </a>
  </div>
</section>

<style>
  .lg-cta {
    position: relative; overflow: hidden; isolation: isolate;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 5vw, 4rem); text-align: center;
    background-color: #b189db;
  }
  /* checkerboard on its own oversized layer — gentle diagonal drift (GPU transform) */
  .lg-cta-checker {
    position:absolute; inset:-120px; z-index:0; pointer-events:none;
    background-color: #b189db;
    background-image:
      linear-gradient(45deg, #bd9ce3 25%, transparent 25%),
      linear-gradient(-45deg, #bd9ce3 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #bd9ce3 75%),
      linear-gradient(-45deg, transparent 75%, #bd9ce3 75%);
    background-size: 96px 96px;
    background-position: 0 0, 0 48px, 48px -48px, -48px 0;
    animation: lg-checker-drift 26s linear infinite; will-change: transform;
  }
  @keyframes lg-checker-drift { to { transform: translate3d(96px, 96px, 0); } }
  @media (prefers-reduced-motion: reduce) { .lg-cta-checker { animation: none; } }
  /* soft center scrim so the white text/form reads on the lighter checker — kept subtle */
  .lg-cta::before {
    content:''; position:absolute; inset:0; z-index:1; pointer-events:none;
    background: radial-gradient(ellipse 80% 70% at 50% 48%, rgba(48,18,82,.32), rgba(48,18,82,0) 72%);
  }

  .lg-cta-inner { position: relative; z-index: 2; max-width: 46rem; margin: 0 auto; }
  .lg-cta-title { color:#fff; font-family:'Inter',sans-serif; font-weight:800; font-size:clamp(2.2rem,5.5vw,3.75rem); line-height:1.02; letter-spacing:-.03em; margin:0 0 .7rem; text-shadow:0 3px 24px rgba(30,10,60,.35); }
  .lg-cta-sub { font-family:'Inter',sans-serif; font-weight:500; font-size:clamp(1rem,1.4vw,1.2rem); color:rgba(255,255,255,.92); margin:0 0 2.1rem; text-shadow:0 1px 10px rgba(30,10,60,.3); }

  .lg-cta-form { display:flex; align-items:stretch; gap:.25rem; max-width:38rem; margin:0 auto; background:rgba(255,255,255,.1); border:1.5px solid rgba(255,255,255,.6); border-radius:.6rem; padding:.4rem; backdrop-filter: blur(4px); }
  .lg-cta-form input { flex:1; min-width:0; background:transparent; border:0; color:#fff; font:inherit; font-size:1rem; padding:.7rem .9rem; }
  .lg-cta-form input::placeholder { color:rgba(255,255,255,.72); }
  .lg-cta-form input:focus { outline:none; }
  .lg-cta-form input[name=phone] { flex:0 0 38%; }
  .lg-cta-div { width:1px; background:rgba(255,255,255,.35); margin:.4rem 0; }
  .lg-cta-form button { flex:0 0 auto; width:3rem; border:0; border-radius:.4rem; background:#fff; color:#5e3299; cursor:pointer; display:grid; place-items:center; transition: transform .15s ease, background .15s ease; }
  .lg-cta-form button svg { width:1.25rem; height:1.25rem; }
  @media (hover:hover){ .lg-cta-form button:hover { transform: translateX(2px); } }

  .lg-cta-consent { font-family:'Inter',sans-serif; font-size:.82rem; color:rgba(255,255,255,.68); margin:1.1rem auto 0; max-width:30rem; line-height:1.5; }

  .lg-cta-wa { display:inline-flex; align-items:center; gap:.55rem; margin-top:2.2rem; font-family:'Inter',sans-serif; font-weight:600; font-size:.95rem; color:#fff; text-decoration:none; opacity:.92; transition: opacity .2s ease; text-shadow:0 1px 10px rgba(30,10,60,.32); }
  .lg-cta-wa svg { width:1.3rem; height:1.3rem; }
  @media (hover:hover){ .lg-cta-wa:hover { opacity:1; } }

  @media (max-width:600px){
    .lg-cta-form { flex-wrap:wrap; }
    .lg-cta-form input[name=phone] { flex:1 1 100%; }
    .lg-cta-div { display:none; }
    .lg-cta-form input[name=need] { flex:1 1 calc(100% - 3.3rem); }
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-waform]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const wa = form.dataset.wa || '';
      const phone = (form.elements.namedItem('phone') as HTMLInputElement)?.value.trim();
      const need = (form.elements.namedItem('need') as HTMLInputElement)?.value.trim();
      let msg = 'Halo Level Garment, aku mau pesan custom.';
      if (need) msg += ` Kebutuhan: ${need}.`;
      if (phone) msg += ` Nomor WhatsApp-ku: ${phone}.`;
      window.open(`https://wa.me/${wa}?text=` + encodeURIComponent(msg), '_blank', 'noopener');
    });
  });
</script>
