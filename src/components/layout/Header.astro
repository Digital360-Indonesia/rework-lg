---
/**
 * Level Garment header — transparent over a full-screen hero, turns solid white
 * on scroll. Hamburger (opens full-screen menu) · centered logo · search + call.
 * Lower height than KG. Sits below the announcement ticker; on scroll it pins to
 * the very top (ticker hides).
 */
import siteConfig from '../../data/site-config.json';
const nav = (siteConfig as any).navigation || [];
const phone = (siteConfig as any).contact?.phone || '';
const wa = (siteConfig as any).contact?.whatsappUrl || '#';
---
<header id="lg-header" class="lg-header">
  <div class="lg-header-inner">
    <button id="lg-burger" class="lg-burger" aria-label="Buka menu" aria-expanded="false" aria-controls="lg-menu">
      <span></span><span></span><span></span>
    </button>

    <a href="/" class="lg-logo" aria-label="Level Garment — Beranda">
      <img class="lg-logo-w" src="/assets/images/logo/logo-white.webp" alt="Level Garment" width="120" height="36" />
      <img class="lg-logo-c" src="/assets/images/logo/logo-colored.webp" alt="Level Garment" width="120" height="36" />
    </a>

    <div class="lg-actions">
      <button id="lg-search-btn" class="lg-icon" aria-label="Cari">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      </button>
      <a href={`${wa}?text=` + encodeURIComponent('Halo Level Garment, aku mau tanya & pesan custom.')} class="lg-icon" aria-label="Chat WhatsApp" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.06 24l1.69-6.16a11.86 11.86 0 0 1-1.59-5.95C.16 5.34 5.5 0 12.06 0a11.82 11.82 0 0 1 8.41 3.49 11.82 11.82 0 0 1 3.48 8.42c0 6.55-5.34 11.89-11.9 11.89a11.9 11.9 0 0 1-5.68-1.45L.06 24Zm6.6-3.8c1.68.99 3.28 1.59 5.4 1.59 5.45 0 9.89-4.43 9.89-9.88a9.86 9.86 0 0 0-9.88-9.89C6.6 2.02 2.16 6.45 2.16 11.9c0 2.23.65 3.9 1.74 5.65l-1 3.65 3.76-.99ZM17.42 14.5c-.07-.12-.27-.2-.56-.34-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.64.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.76-1.64-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.21-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.22 3.08.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.42.25-.69.25-1.29.18-1.41Z"/></svg>
      </a>
    </div>
  </div>

  <div id="lg-search" class="lg-search" aria-hidden="true">
    <form action="/product/" class="lg-search-form" role="search">
      <input type="search" name="q" placeholder="Cari jersey, jaket angkatan, kaos…" aria-label="Cari produk" />
      <button type="submit" aria-label="Cari">→</button>
    </form>
  </div>
</header>

<div id="lg-menu" class="lg-menu" aria-hidden="true">
  <nav class="lg-menu-nav" aria-label="Menu utama">
    {nav.map((n: any, i: number) => (
      <a href={n.path} style={`--d:${i * 60}ms`}>{n.name}</a>
    ))}
    <a class="lg-menu-cta" href={wa} target="_blank" rel="noopener noreferrer" style={`--d:${nav.length * 60}ms`}>Pesan Sekarang →</a>
  </nav>
</div>

<style>
  :root { --lg-primary: #AF7AD5; --lg-primary-dark: #9A66C2; --lg-ink: #1A1A2E; }

  .lg-header { position: fixed; top: 1.9rem; inset-inline: 0; z-index: 50; transition: top .35s ease, background .35s ease, box-shadow .35s ease; }
  .lg-header-inner { max-width: none; margin: 0 auto; padding: 0 1.6rem; height: 4.3rem; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; }
  .lg-logo { justify-self: center; display: inline-flex; }
  .lg-logo img { height: 2.5rem; width: auto; }
  .lg-logo-w { display: block; } .lg-logo-c { display: none; }
  .lg-burger { justify-self: start; width: 2.15rem; height: 1.5rem; position: relative; background: none; border: 0; cursor: pointer; padding: 0; }
  .lg-burger span { position: absolute; left: 0; right: 0; height: 2.8px; background: #fff; border-radius: 2px; transition: transform .3s ease, opacity .3s ease, background .35s ease; }
  .lg-burger span:nth-child(1){ top: 0; } .lg-burger span:nth-child(2){ top: 50%; transform: translateY(-50%); } .lg-burger span:nth-child(3){ bottom: 0; }
  .lg-actions { justify-self: end; display: inline-flex; gap: .4rem; }
  .lg-icon { display: grid; place-items: center; width: 2.7rem; height: 2.7rem; color: #fff; background: none; border: 0; cursor: pointer; border-radius: 999px; transition: color .35s ease, background .2s ease; text-decoration: none; }
  .lg-icon svg { width: 1.6rem; height: 1.6rem; }
  @media (hover:hover){ .lg-icon:hover{ background: rgba(255,255,255,.16);} }

  .lg-header.is-solid { top: 0; background: #fff; box-shadow: 0 1px 0 rgba(0,0,0,.06), 0 6px 20px -12px rgba(0,0,0,.25); }
  .lg-header.is-solid .lg-logo-w { display: none; } .lg-header.is-solid .lg-logo-c { display: block; }
  .lg-header.is-solid .lg-burger span { background: var(--lg-ink); }
  .lg-header.is-solid .lg-icon { color: var(--lg-ink); }
  @media (hover:hover){ .lg-header.is-solid .lg-icon:hover{ background: #f1ecf8; } }

  body.lg-menu-open .lg-burger span:nth-child(1){ top:50%; transform: translateY(-50%) rotate(45deg); background:#fff; }
  body.lg-menu-open .lg-burger span:nth-child(2){ opacity: 0; }
  body.lg-menu-open .lg-burger span:nth-child(3){ bottom:auto; top:50%; transform: translateY(-50%) rotate(-45deg); background:#fff; }

  .lg-search { max-width: 80rem; margin: 0 auto; padding: 0 1.1rem; overflow: hidden; max-height: 0; transition: max-height .3s ease; }
  .lg-search.is-open { max-height: 4rem; }
  .lg-search-form { display: flex; gap: .5rem; padding: .55rem 0 .8rem; }
  .lg-search-form input { flex: 1; border: 1px solid rgba(255,255,255,.5); background: rgba(255,255,255,.12); color: #fff; border-radius: 999px; padding: .55rem 1rem; font: inherit; font-size: .9rem; }
  .lg-search-form input::placeholder { color: rgba(255,255,255,.8); }
  .lg-header.is-solid .lg-search-form input { border-color: #e3dcef; background: #f6f3fb; color: var(--lg-ink); }
  .lg-header.is-solid .lg-search-form input::placeholder { color: #8a86a0; }
  .lg-search-form button { background: var(--lg-primary); color:#fff; border:0; width: 2.6rem; border-radius: 999px; font-size: 1.1rem; cursor: pointer; }

  .lg-menu { position: fixed; inset: 0; z-index: 49; background: var(--lg-primary); color: #fff; display: grid; place-items: center; opacity: 0; visibility: hidden; transition: opacity .4s ease, visibility .4s; }
  body.lg-menu-open .lg-menu { opacity: 1; visibility: visible; }
  .lg-menu-nav { display: flex; flex-direction: column; gap: .35rem; text-align: center; }
  .lg-menu-nav a { font-family: 'Inter', sans-serif; font-weight: 700; font-size: clamp(1.9rem, 6vw, 3.25rem); letter-spacing: -.02em; color: #fff; text-decoration: none; opacity: 0; transform: translateY(14px); transition: opacity .5s ease, transform .5s cubic-bezier(.19,1,.22,1); transition-delay: var(--d); }
  body.lg-menu-open .lg-menu-nav a { opacity: 1; transform: none; }
  @media (hover:hover){ .lg-menu-nav a:hover { color: #FFC107; } }
  .lg-menu-cta { margin-top: 1.2rem; font-size: clamp(1rem,2.5vw,1.25rem) !important; background:#fff; color: var(--lg-primary) !important; padding: .7rem 1.6rem; border-radius: 999px; }
</style>

<script>
  const header = document.getElementById('lg-header');
  const ticker = document.querySelector<HTMLElement>('.lg-ticker');
  if (ticker) ticker.style.transition = 'transform .35s ease';
  const onScroll = () => {
    const solid = window.scrollY > 24;
    header?.classList.toggle('is-solid', solid);
    if (ticker) ticker.style.transform = solid ? 'translateY(-100%)' : '';
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const burger = document.getElementById('lg-burger');
  burger?.addEventListener('click', () => {
    const open = document.body.classList.toggle('lg-menu-open');
    burger.setAttribute('aria-expanded', String(open));
    document.getElementById('lg-menu')?.setAttribute('aria-hidden', String(!open));
    document.body.style.overflow = open ? 'hidden' : '';
  });

  const searchBtn = document.getElementById('lg-search-btn');
  const search = document.getElementById('lg-search');
  searchBtn?.addEventListener('click', () => {
    const open = search?.classList.toggle('is-open');
    search?.setAttribute('aria-hidden', String(!open));
    if (open) (search?.querySelector('input') as HTMLInputElement)?.focus();
  });
</script>
