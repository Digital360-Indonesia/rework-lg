---
/**
 * Footer Component - Level Garment
 * Single footer component with no duplication
 */

const footerLogo = "/assets/images/logo/lg-logo.png";

const socialLinks = [
  { name: 'Instagram', url: 'https://www.instagram.com/levelgarment/', icon: 'instagram' },
  { name: 'TikTok', url: 'https://www.tiktok.com/@levelgarment', icon: 'tiktok' },
  { name: 'Facebook', url: '#', icon: 'facebook' },
  { name: 'YouTube', url: '#', icon: 'youtube' },
];

const additionalLinks = [
  { name: 'Product', url: '/product/' },
  { name: 'Promo', url: '/promo/' },
  { name: 'Portfolio', url: 'https://portfolio.levelgarment.com' },
  { name: 'Katalog Jersey', url: '/katalog-jersey-baseball' },
  { name: 'Sitemap', url: '/sitemap/' },
];

const fomoLinks = [
  { name: 'Fomo News', url: '/berita' },
  { name: 'Marketing Gallery', url: '#' },
  { name: 'Sponsor & Partnership', url: '#' },
];
---

<footer id="footer" class="bg-primary text-white overflow-x-hidden">

  <!-- Stay In Touch -->
  <div class="bg-white py-8 lg:py-12">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <div>
          <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold mb-2 text-primary">Stay In Touch</h2>
          <p class="text-gray-600 mb-4 text-sm sm:text-base">Langsung chat whatsapp official Level Garment & dapetin spesial cashback!</p>
          <a href="https://wa.me/6285183091599" target="_blank" rel="noopener noreferrer" class="inline-block px-6 py-2.5 sm:px-8 sm:py-3 bg-primary text-white font-bold text-sm sm:text-base rounded-full hover:bg-primary-dark transition-colors">Get Cashback Now!</a>
        </div>
        <div>
          <h3 class="font-semibold text-gray-800 mb-3 text-sm sm:text-base">Quick Links</h3>
          <ul class="space-y-2">
            {additionalLinks.map(link => <li><a href={link.url} class="text-gray-600 hover:text-primary text-sm sm:text-base">{link.name}</a></li>)}
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-gray-800 mb-3 text-sm sm:text-base">More</h3>
          <ul class="space-y-2">
            {fomoLinks.map(link => <li><a href={link.url} class="text-gray-600 hover:text-primary text-sm sm:text-base">{link.name}</a></li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Section -->
  <div class="py-6 lg:py-8 border-t border-gray-200 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="text-sm text-gray-600 space-y-2 order-2 md:order-1">
          <p class="flex items-start gap-2">
            <svg class="w-4 h-4 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="break-words">Jl. Sidosermo IV Gg. III No. 37 (Raya Prapen), Sidosermo, Surabaya</span>
          </p>
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span>0851 8309 1599</span>
          </p>
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span class="break-all">marketing@levelgarment.com</span>
          </p>
        </div>
        <div class="flex flex-col md:items-end gap-3 order-1 md:order-2">
          <img src={footerLogo} alt="Level Garment" class="h-10 sm:h-12 lg:h-14 w-auto mx-auto md:mx-0" />
          <div class="flex gap-2 justify-center md:justify-end">
            {socialLinks.map(link => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="social-icon group flex items-center justify-center" aria-label={link.name}>
                {link.icon === 'instagram' && (
                  <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 448 512"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7 2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"></path></svg>
                )}
                {link.icon === 'tiktok' && (
                  <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 448 512"><path d="M448,209.91a210.06,210.06,0,0,1-122.77-39.25V349.38A162.55,162.55,0,1,1,185,188.31V278.2a74.62,74.62,0,1,0,52.23,71.18V0l88,0a121.18,121.18,0,0,0,1.86,22.17h0A122.18,122.18,0,0,0,381,102.39a121.43,121.43,0,0,0,67,20.14Z"></path></svg>
                )}
                {link.icon === 'facebook' && (
                  <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 320 512"><path d="M80 299.3V512H196V299.3h86.5l18-97.8H196V166.9c0-51.7 20.3-71.5 72.7-71.5c16.3 0 29.4 .4 37 1.2V7.9C291.4 4 256.4 0 236.7 0C129.3 0 80 50.3 80 159.4v42.1H14v97.8H80z"></path></svg>
                )}
                {link.icon === 'youtube' && (
                  <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 576 512"><path d="M549.7 124.1c-6.3-23.7-24.8-42.3-48.3-48.6C458.8 64 288 64 288 64s-170.8 0-213.4 11.5c-23.6 6.3-42.1 24.9-48.3 48.6C11.5 177.1 11.5 256 11.5 256s0 78.9 14.8 131.9c6.3 23.7 24.8 42.3 48.3 48.6c42.7 11.5 213.4 11.5 213.4 11.5s170.8 0 213.4-11.5c23.6-6.3 42.1-24.9 48.3-48.6c14.8-53 14.8-131.9 14.8-131.9s0-78.9-14.8-131.9zm-317.5 213.5V175.2l142.7 81.2-142.7 81.2z"></path></svg>
                )}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="py-3 sm:py-4 border-t border-white/10 text-center bg-primary">
    <p class="text-xs sm:text-sm text-white px-4">© 2025 Level Garment. All Rights Reserved. Made with Passion by <a href="https://digital360.id" target="_blank" rel="noopener noreferrer" class="text-white hover:text-gray-200">Digital360</a></p>
  </div>
</footer>

<style>
  footer a {
    transition: all 0.3s ease;
  }

  /* Social icon styles */
  .social-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background-color: #AF7AD5;
    color: white;
    transition: all 0.3s ease;
  }

  @media (min-width: 640px) {
    .social-icon {
      width: 2.5rem;
      height: 2.5rem;
    }
  }

  .social-icon:hover {
    transform: scale(1.15) rotate(5deg);
    background-color: #9A66C2;
  }

  .social-icon svg {
    transition: all 0.3s ease;
  }

  .social-icon:hover svg {
    transform: scale(1.1);
  }
</style>
